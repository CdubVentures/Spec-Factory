# ==========================================
# Spec Factory Runtime Environment
# ==========================================
# API keys and secrets are managed through the GUI and persisted to SQL.
# Setting them here has NO effect — the config pipeline ignores env for
# secret keys. Use the GUI Settings page to configure API keys.
#
# Non-secret env vars (PORT, LOG_STDOUT, etc.) still work from .env.
# ==========================================

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
