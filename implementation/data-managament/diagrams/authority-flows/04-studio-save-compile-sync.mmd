sequenceDiagram
  participant U as User
  participant FE as StudioPage
  participant API as studioRoutes
  participant CC as categoryCompile
  participant PC as compileProcessCompletion
  participant SY as syncSpecDbForCategory
  participant SD as seedSpecDb
  participant DB as data_authority_sync
  participant WS as WebSocket(data-change)
  participant APP as AppShell + subscribers

  U->>FE: Edit rules/map
  FE->>API: POST /studio/{category}/validate-map
  API->>CC: validateWorkbookMap(map)
  CC-->>API: valid/invalid + normalized
  API-->>FE: validation result

  alt Save mapping
    FE->>API: PUT /studio/{category}/workbook-map(normalized)
    API->>CC: saveWorkbookMap
    CC-->>API: map_hash + snapshot
    API->>WS: emit workbook-map-saved
    WS->>APP: data-change
    APP->>APP: invalidate mapped queries
  end

  alt Save drafts
    FE->>API: POST /studio/{category}/save-drafts(store snapshot)
    API->>WS: emit studio-drafts-saved
    WS->>APP: data-change
    APP->>APP: invalidate mapped queries
  end

  alt Compile
    FE->>API: POST /studio/{category}/compile
    API-->>FE: process started
    API->>PC: process exits success
    PC->>SY: syncSpecDbForCategory(category)
    SY->>SD: seedSpecDb(db, fieldRules, json sources)
    SD-->>SY: sync metrics
    SY->>DB: recordSpecDbSync(status/version/meta)
    SY-->>PC: sync result or failure metadata
    PC->>WS: emit process-completed(version/meta)
    WS->>APP: data-change
    APP->>APP: invalidate mapped queries + snapshot query
  end
