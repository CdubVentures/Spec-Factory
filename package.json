{
  "name": "spec-harvester",
  "version": "1.0.0",
  "description": "Backend-first mouse spec harvester",
  "type": "module",
  "main": "src/app/cli/spec.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "env:check": "node tools/check-env-example-sync.mjs",
    "setup:bootstrap": "node tools/setup-deps.mjs",
    "setup:gui": "node tools/specfactory-launcher.mjs",
    "setup:exe": "node tools/build-setup-exe.mjs",
    "test": "node --test --test-force-exit",
    "run:one": "node src/app/cli/spec.js run-one",
    "run:indexlab": "node src/app/cli/spec.js indexlab",
    "run:adhoc": "node src/app/cli/spec.js run-ad-hoc",
    "run:batch": "node src/app/cli/spec.js run-batch",
    "discover": "node src/app/cli/spec.js discover",
    "discover-sources": "node src/app/cli/spec.js discover",
    "crawl-product": "node src/app/cli/spec.js run-one",
    "intel:api": "node src/app/cli/spec.js intel-graph-api --category mouse --port 8787 --local",
    "smoke": "node src/app/cli/spec.js run-one --local --dry-run --s3key specs/inputs/mouse/products/mouse-razer-viper-v3-pro.json",
    "smoke:local": "node src/app/cli/smokeLocal.js",
    "gui:api": "node src/app/api/guiServer.js --port 8788 --local",
    "gui:dev": "cd tools/gui-react && npm run dev",
    "gui:build": "cd tools/gui-react && npm run build",
    "gui:start": "npm run gui:build && npm run gui:api",
    "gui:exe": "node tools/build-exe.mjs",
    "docs:render:authority-diagrams": "node tools/render-authority-mermaid.mjs"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@duckduckgo/autoconsent": "^14.64.0",
    "@mozilla/readability": "^0.6.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.3",
    "crawlee": "^3.16.0",
    "jsdom": "^28.1.0",
    "pdf-parse": "^1.1.4",
    "playwright": "^1.58.2",
    "playwright-autoconsent": "^1.0.4",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
