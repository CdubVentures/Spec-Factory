graph TD
    subgraph CIRCUIT["Circuit Breaker - providerHealth.js"]
        CB_CLOSED["CLOSED\nAccept requests\nFailure count: 0"]
        CB_HALF["HALF_OPEN\nTest recovery\nSingle request"]
        CB_OPEN["OPEN\nReject all\n60s cooldown"]
    end

    subgraph FALLBACK["Fallback Strategy"]
        F1["Primary model call"]
        F2["Primary fails"]
        F3["Fallback model available?"]
        F4["Try fallback model"]
        F5["Retry without JSON schema"]
        F6["Return error"]
    end

    subgraph JSON_PARSE["JSON Recovery Pipeline"]
        J1["1. Direct JSON.parse"]
        J2["2. Extract from code block"]
        J3["3. Balanced-brace extraction"]
        J4["4. Best-score selection"]
    end

    subgraph BUDGET_GUARD["Budget Protection"]
        BG1["essential=true\nHard error if exceeded"]
        BG2["essential=false\nSkip call gracefully"]
        BG3["Budget exhausted\nBlock further calls"]
    end

    CB_CLOSED -->|"5 consecutive failures"| CB_OPEN
    CB_OPEN -->|"60s cooldown expires"| CB_HALF
    CB_HALF -->|"success"| CB_CLOSED
    CB_HALF -->|"failure"| CB_OPEN

    F1 --> F2
    F2 --> F3
    F3 -->|"yes"| F4
    F3 -->|"no"| F5
    F5 -->|"fail"| F6

    J1 -->|"fail"| J2
    J2 -->|"fail"| J3
    J3 -->|"fail"| J4

    BG3 --> BG1
    BG3 --> BG2

    style CIRCUIT fill:#d63031,stroke:#ff7675,color:#fff
    style FALLBACK fill:#e17055,stroke:#fab1a0,color:#fff
    style JSON_PARSE fill:#fdcb6e,stroke:#ffeaa7,color:#2d3436
    style BUDGET_GUARD fill:#0984e3,stroke:#74b9ff,color:#fff
