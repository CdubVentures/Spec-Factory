graph TB
    subgraph GUARD["Budget Guard - Limits"]
        G1["Monthly Budget\nDefault $300"]
        G2["Per-Product Budget\nDefault $0.35"]
        G3["Per-Round Call Limit\n5 calls"]
        G4["Per-Product Total\n14 calls"]
        G5["Per-Product Fast\n6 calls"]
    end

    subgraph TRACKING["Cost Tracking"]
        T1["costRates.js\nNormalize per-model pricing"]
        T2["computeLlmCostUsd\ntokens x rate / 1M"]
        T3["estimateTokensFromText\n1 token per 3.8 chars"]
    end

    subgraph LEDGER["Cost Ledger - Persistence"]
        L1["Monthly JSONL\n_billing/ledger/YYYY-MM.jsonl"]
        L2["Monthly Rollup\n_billing/monthly/YYYY-MM.json"]
        L3["Monthly Digest\n_billing/monthly/YYYY-MM.txt"]
        L4["Flat Ledger\n_billing/ledger.jsonl"]
    end

    subgraph PRICING["Pricing Catalog"]
        P1["modelPricingCatalog.js"]
        P2["GPT-5 family rates"]
        P3["Gemini 2.5 family rates"]
        P4["DeepSeek model rates"]
    end

    subgraph DECISIONS["Budget Decisions"]
        D1["essential=true\nHard error if exceeded"]
        D2["essential=false\nSkip call gracefully"]
    end

    GUARD --> DECISIONS
    GUARD --> TRACKING
    T1 --> T2
    T3 --> T2
    T2 --> LEDGER
    PRICING --> T1
    P1 --> P2
    P1 --> P3
    P1 --> P4

    style GUARD fill:#d63031,stroke:#ff7675,color:#fff
    style TRACKING fill:#e17055,stroke:#fab1a0,color:#fff
    style LEDGER fill:#fdcb6e,stroke:#ffeaa7,color:#2d3436
    style PRICING fill:#0984e3,stroke:#74b9ff,color:#fff
    style DECISIONS fill:#00b894,stroke:#55efc4,color:#fff
