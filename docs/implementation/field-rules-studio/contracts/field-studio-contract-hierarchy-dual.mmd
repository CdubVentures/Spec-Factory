flowchart LR
  ROOT["FIELD STUDIO CONTRACT HIERARCHY (DUAL PANEL)<br/>Legend: [x] verified | [flag] actionable flag | [!] tracked gap"]

  subgraph LEFT["Panel A - Capture and Compile Contract"]
    direction TB
    L0["[x] Authoring sources<br/>field_studio_map (saved docs)"]
    L1["[x] Field Studio capture scope<br/>selected_keys -> field_overrides entries"]
    L2["[x] Component source schema<br/>roles.properties requires key/type/unit/variance/constraints"]
    L3["[x] Policy support<br/>enum: open|open_prefer_known|closed|closed_with_curation<br/>variance: authoritative|upper_bound|lower_bound|range|override_allowed"]
    L4["[x] Numeric guard<br/>numeric variance on non-number type coerces to authoritative with warning"]
    L5["[x] Compile outputs<br/>field_rules.json + component_db/*.json + known_values.json"]
    L6["[x] Drift guard<br/>mouse sensor dpi/ips/acceleration remain numeric upper_bound (FRC-05-E)"]
    L7["[!] closed_with_curation compile-valid but no dedicated test-mode scenario branch"]
    L0 --> L1 --> L2 --> L3 --> L4 --> L5 --> L6
    L3 --> L7
  end

  subgraph RIGHT["Panel B - Review Projection and UI Contract"]
    direction TB
    R1["[x] Review route payload<br/>compiled rules merged with session mergedFields"]
    R2["[x] Component payload columns<br/>observed columns UNION declared contract columns"]
    R3["[x] Blank declared columns preserved<br/>drawer shows slot with null-selected state"]
    R4["[x] Slot aggregation invariant<br/>C(K,F) on linked products for name/maker/properties"]
    R5["[x] Actionable flags<br/>[flag] variance_violation, constraint_conflict,<br/>compound_range_conflict, dependency_missing,<br/>new_component, new_enum_value,<br/>below_min_evidence"]
    R6["[!] metrics.flags semantics differ by domain<br/>item grid uses real flag taxonomy,<br/>component/enum grids count needs_review rows"]
    R1 --> R2 --> R3 --> R4 --> R5 --> R6
  end

  ROOT --> LEFT
  ROOT --> RIGHT
  L5 --> R1
  L2 --> R2
  L3 --> R5

  classDef rootStyle fill:#0f172a,stroke:#1d4ed8,stroke-width:3px,color:#f8fafc,font-weight:bold;
  classDef leftStyle fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#082f49;
  classDef rightStyle fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#14532d;
  classDef gapStyle fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#7c2d12;

  class ROOT rootStyle
  class L0,L1,L2,L3,L4,L5,L6 leftStyle
  class R1,R2,R3,R4,R5 rightStyle
  class L7,R6 gapStyle
