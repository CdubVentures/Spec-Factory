flowchart LR
  ROOT["FIELD STUDIO CONTRACT - PANEL A (CAPTURE TO COMPILE)<br/>Legend: [x] verified | [flag] actionable flag | [!] tracked gap"]

  subgraph A1["A1. Authoring Sources"]
    direction TB
    S0["[x] field_studio_map carries saved selected_keys + field_overrides"]
    S1["[x] selected_keys defines active field scope"]
    S2["[x] selected key coverage rule<br/>each selected key must map to a field_overrides entry"]
    S3["[x] field_overrides carries contract/parse/enum/component/evidence/priority/selection/ui"]
    S0 --> S1 --> S2 --> S3
  end

  subgraph A2["A2. Component Source Capture"]
    direction TB
    C1["[x] component_sources rows define type + role columns"]
    C2["[x] roles.properties capture key/type/unit/variance/constraints"]
    C3["[x] property_keys can be derived from roles.properties.field_key"]
    C4["[x] compile emits component_db and field rule component.match config"]
    C1 --> C2 --> C3 --> C4
  end

  subgraph A3["A3. Policy Contract and Guards"]
    direction TB
    P1["[x] enum policy support<br/>open, open_prefer_known, closed, closed_with_curation"]
    P2["[x] variance policy support<br/>authoritative, upper_bound, lower_bound, range, override_allowed"]
    P3["[x] numeric-only guard for upper/lower/range on property types"]
    P4["[x] coercion warning path when numeric variance is authored on string"]
    P5["[x] regression guard FRC-05-E<br/>mouse sensor dpi/ips/acceleration stay numeric upper_bound"]
    P6["[!] closed_with_curation compile-valid but no dedicated test-mode scenario branch"]
    P1 --> P2 --> P3 --> P4 --> P5
    P1 --> P6
  end

  subgraph A4["A4. Compile Outputs and Runtime Input"]
    direction TB
    O1["[x] generated: field_rules.json, field_rules.runtime.json, known_values.json, component_db/*.json"]
    O2["[x] loadCategoryConfig projects compiled + saved map overrides"]
    O3["[x] review routes consume projected field rules"]
    O1 --> O2 --> O3
  end

  ROOT --> A1 --> A2 --> A3 --> A4
  A2 --> A4
  A3 --> A4

  classDef rootStyle fill:#0f172a,stroke:#1d4ed8,stroke-width:3px,color:#f8fafc,font-weight:bold;
  classDef sourceStyle fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#082f49;
  classDef policyStyle fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#14532d;
  classDef outStyle fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#78350f;
  classDef gapStyle fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#7c2d12;

  class ROOT rootStyle
  class S0,S1,S2,S3,C1,C2,C3,C4 sourceStyle
  class P1,P2,P3,P4,P5 policyStyle
  class O1,O2,O3 outStyle
  class P6 gapStyle
