flowchart LR
    subgraph BOOT["Bootstrap"]
        direction TB
        B0["runProduct()<br/>run id + logger + trace writer<br/>identity lock + runtime overrides<br/>planner + frontier + resume<br/>learning profile + store-hint readback"]
    end

    subgraph DISCOVERY["Phase A: Discovery (01-08)"]
        direction TB
        subgraph PARALLEL["Parallel: Promise.all()"]
            direction LR
            S01["01 NeedSet<br/>computeNeedSet() pure<br/>buildSearchPlanningContext()<br/>buildSearchPlan() LLM"]
            S02["02 Brand Resolver<br/>cache-first domain lookup<br/>LLM fallback<br/>officialDomain + aliases"]
        end
        S03["03 Search Profile<br/>deterministic query rows<br/>tier allocation (seed/group/key)<br/>queryBuilder + capMap"]
        S04["04 Search Planner<br/>LLM query enhancement<br/>identity lock guard<br/>deterministic fallback"]
        S05["05 Query Journey<br/>dedup + identity guard<br/>searchProfileQueryCap<br/>reject log aggregation"]
        S06["06 Search Results<br/>provider dispatch (config-driven)<br/>Serper burst / SearXNG / Google / Brave<br/>dedup + video + crawled filter<br/>frontier cache + plan-only fallback"]
        S07["07 SERP Selector<br/>hard-drop filter (denied/utility)<br/>LLM URL selection (all candidates, max_keep output cap)<br/>host trust + doc kind enrichment"]
        S08["08 Domain Classifier<br/>domainClassifierUrlCap<br/>triage metadata map<br/>planner.enqueue() approved URLs"]

        PARALLEL --> S03 --> S04 --> S05 --> S06 --> S07 --> S08
    end

    subgraph CRAWL["Phase B: Crawl"]
        direction TB
        C01["Crawl Session<br/>PlaywrightCrawler (persistent)<br/>plugin hooks: before/after/interact/capture/complete<br/>worker slots for GUI visibility"]
        C02["Crawl Plugins (Registry)<br/>stealth + cookieConsent<br/>autoScroll + domExpansion<br/>cssOverride"]
        C03["Block Detection<br/>classifyBlockStatus() pure<br/>status-based + content-based<br/>CF/CAPTCHA/access denied markers"]
        C01 --> C02 --> C03
    end

    subgraph EXTRACT["Phase C: Extraction"]
        direction TB
        E01["Extraction Runner<br/>sequential plugin execution<br/>deep-frozen context (Object.freeze)<br/>per-plugin error isolation"]
        E02["Extraction Plugins (Registry)<br/>screenshot (captureScreenshots)<br/>selector crops + full-page<br/>O(1) plugin addition"]
        E01 --> E02
    end

    ART["Durable Outputs<br/>runs/ + latest/<br/>searchProfile + discovery + candidates<br/>logs/events.jsonl.gz + traces"]
    GOOGLE["Google Crawlee Sidecar<br/>searchGoogle() headless browser<br/>SERP screenshot capture<br/>captcha/consent returns empty"]
    LEARN["Learning Loop<br/>store-hint readback on bootstrap<br/>search plan learning_writeback<br/>domain yield + anchor reuse"]
    ZOD["Zod Checkpoints<br/>cumulative pipeline context schema<br/>8 progressive checkpoints<br/>pipelineSchemaEnforcementMode"]

    B0 --> DISCOVERY
    S08 --> CRAWL
    C03 --> EXTRACT
    S06 -.->|google via Crawlee| GOOGLE
    E02 --> ART
    LEARN -.->|next run hints + seeds| B0

    PARALLEL -.->|Zod checkpoint| ZOD
    S05 -.->|Zod checkpoint| ZOD
    S07 -.->|Zod checkpoint| ZOD

