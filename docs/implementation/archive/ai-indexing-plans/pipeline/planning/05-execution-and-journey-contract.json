{
  "_doc": "Merged execution + journey contracts: Google transport, SearXNG transport, Query Journey LLM call status, and Query Journey output. Validated against live code 2026-03-23.",
  "validated_against": "2026-03-23",

  "google_transport": {
    "entrypoint": "src/features/indexing/search/searchGoogle.js :: searchGoogle()",
    "activation_gate": {
      "transport_router": "src/features/indexing/search/searchProviders.js :: splitEnginesByTransport()",
      "path_enabled_when": "normalized searchEngines contains google",
      "independent_of_searxng": true
    },
    "input_shape": {
      "query": "string",
      "limit": "number",
      "timeoutMs": "number",
      "proxyUrls": "string[]",
      "minQueryIntervalMs": "number",
      "postResultsDelayMs": "number",
      "headless": "boolean",
      "screenshotsEnabled": "boolean",
      "screenshotQuality": "number",
      "logger": "logger|null",
      "requestThrottler": "object|null"
    },
    "runtime_behavior": [
      "module-level pacing plus optional requestThrottler.acquire()",
      "headless Crawlee/Playwright using system Chrome channel",
      "stealth init script and Google-specific browser hardening",
      "optional proxy rotation through Crawlee ProxyConfiguration",
      "consent dismissal attempt",
      "early CAPTCHA detection and session burn",
      "optional cropped JPEG screenshot capture",
      "parseGoogleResults() on the rendered DOM"
    ],
    "non_fatal_empty_cases": ["CAPTCHA page", "consent page", "crawler error"],
    "output_shape": {
      "results": [{ "url": "string", "title": "string", "snippet": "string", "provider": "google", "query": "string" }],
      "screenshot": { "buffer": "Buffer", "width": 1920, "height": 1080, "bytes": "number", "ts": "ISO timestamp", "queryHash": "string" }
    }
  },

  "searxng_transport": {
    "query_inputs": {
      "queries": "string[]",
      "selectedQueryRowMap": "Map of planned query metadata",
      "executionQueryLimit": "number",
      "queryConcurrency": "number",
      "resultsPerQuery": "number"
    },
    "provider_state": {
      "owner": "src/features/indexing/search/searchProviders.js :: searchEngineAvailability()",
      "keys": ["provider", "engines", "bing_ready", "google_ready", "google_search_ready", "searxng_ready", "active_providers", "fallback_engines", "fallback_ready", "fallback_reason", "internet_ready"]
    },
    "transport_split": {
      "google_path": "attemptGoogleCrawlee() -> searchGoogle()",
      "searxng_path": "attemptSearch() -> searchSearxng()",
      "fallback_path": "searchEnginesFallback only when the primary provider attempt returns zero rows"
    },
    "executeSearchQueries_flow": [
      "emit search_provider_diagnostics",
      "optional internal-first corpus search",
      "optional frontier cache reuse before live provider calls",
      "run live provider calls under runWithConcurrency()",
      "query-level frontier reuse when live provider results are empty",
      "plan-only manufacturer fallback only when no provider path exists and rawResults is still empty"
    ],
    "searchSearxng_contract": {
      "input": { "baseUrl": "string", "query": "string", "limit": "number", "timeoutMs": "number", "minQueryIntervalMs": "number", "engines": "CSV string", "provider": "string", "logger": "logger|null", "requestThrottler": "object|null" },
      "behavior": ["serialized pacing chain to avoid upstream engine bursts", "garbage-engine filtering by query-word overlap", "URL dedupe"],
      "output_row": { "url": "string", "title": "string", "snippet": "string", "provider": "engine name", "engines": "string[]", "query": "string" }
    },
    "executeSearchQueries_return": {
      "rawResults": "array of provider rows",
      "searchAttempts": "array of attempt summary rows",
      "searchJournal": "array of timestamped journal rows",
      "internalSatisfied": "boolean",
      "externalSearchReason": "string|null"
    }
  },

  "query_journey_llm_status": {
    "_doc": "There is no Query Journey-owned LLM call in the current implementation.",
    "llm_call": false,
    "implemented_by": [
      "src/features/indexing/pipeline/queryJourney/runQueryJourney.js",
      "src/features/indexing/pipeline/shared/queryPlan.js"
    ],
    "operations": [
      "receive enhanced rows from Search Planner (LLM-enhanced or deterministic fallback — treated identically)",
      "dedupeQueryRows(queryCandidates, dedupeQueriesCap)",
      "cap to searchProfileQueryCap via .slice(0, mergedQueryCap)",
      "enforceIdentityQueryGuard()",
      "build llm_queries from rows where hint_source ends with _llm",
      "write planned search_profile artifact"
    ],
    "adjacent_llm_surfaces": [
      { "surface": "NeedSet search plan planner", "when": "before Query Journey (NeedSet phase)", "owner": "src/indexlab/searchPlanBuilder.js", "reason": "needset_search_planner" },
      { "surface": "Search Planner phase (tier-aware enhancement)", "when": "immediately before Query Journey", "owner": "src/research/queryPlanner.js (enhanceQueryRows)", "reason": "search_planner_enhance" },
      { "surface": "SERP selector / reranker", "when": "after Query Journey (Result Processing phase)", "owner": ["src/features/indexing/pipeline/resultProcessing/serpSelectorLlmAdapter.js", "src/research/serpReranker.js"], "reason": ["serp_url_selector", "uber_serp_reranker"] }
    ]
  },

  "query_journey_output": {
    "runQueryJourney_return": {
      "queries": "final execution query strings",
