      "profileQueryRowsByQuery": "Map of deterministic profile rows keyed by lowercased query",
      "searchProfilePlanned": {
        "status": "planned",
        "provider": "config.searchEngines",
        "llm_queries": "query texts from enhanced rows where hint_source ends with _llm (Search Planner LLM-enhanced only). Empty when LLM failed.",
        "selected_queries": "string[]",
        "selected_query_count": "number",
        "query_rows": "selected query rows after merge/rank/guard",
        "query_reject_log": "combined reject log",
        "query_guard": { "brand_tokens": "string[]", "model_tokens": "string[]", "required_digit_groups": "string[]", "accepted_query_count": "number", "rejected_query_count": "number" },
        "brand_resolution": "object|null",
        "search_plan_planner": "object|null",
        "search_plan_learning": "object|null",
        "search_plan_panel": "object|null",
        "key": "string",
        "run_key": "string|null",
        "latest_key": "string|null"
      },
      "searchProfileKeys": { "inputKey": "string", "runKey": "string|null", "latestKey": "string|null" },
      "executionQueryLimit": "number",
      "queryLimit": "number",
      "queryRejectLogCombined": "array"
    },
    "search_execution_return": {
      "rawResults": "provider rows plus plan-only rows when applicable",
      "searchAttempts": "attempt summary rows",
      "searchJournal": "timestamped journal rows",
      "internalSatisfied": "boolean",
      "externalSearchReason": "string|null"
    },
    "canonical_query_concurrency_note": {
