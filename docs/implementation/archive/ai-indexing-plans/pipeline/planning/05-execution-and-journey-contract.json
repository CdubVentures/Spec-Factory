        "candidate_count": "number",
        "llm_query_planning": true,
        "llm_query_model": "string",
        "llm_serp_triage": "boolean",
        "llm_serp_triage_model": "string",
        "serp_explorer": { "llm_selector_enabled": "boolean", "llm_selector_applied": "boolean", "llm_triage_enabled": "boolean", "llm_triage_applied": "boolean" }
      },
      "discovery_payload": {
        "provider_state": "searchEngineAvailability() result",
        "query_concurrency": "number",
        "queries": "string[]",
        "query_guard": "object|null",
        "query_reject_log": "array",
        "llm_queries": "array; canonical callers currently pass []",
        "uber_search_plan": "object|null",
        "targeted_missing_fields": "string[]",
        "internal_satisfied": "boolean",
        "external_search_reason": "string|null",
        "search_attempts": "array",
        "search_journal": "array",
        "serp_explorer": "object",
        "discovered": "selected discovery rows"
      },
      "candidate_payload": { "candidate_count": "number", "candidates": "candidate-only rows" }
    },
    "processDiscoveryResults_return": {
      "_doc": "Verified against processDiscoveryResults.js (2026-03-23)",
      "enabled": true,
      "discoveryKey": "string",
      "candidatesKey": "string",
      "candidates": "Array<object> -- candidateRowsFinal (approved + not-selected + overflow, triage-annotated)",
      "selectedUrls": "string[] -- URLs selected by SERP selector LLM",
      "allCandidateUrls": "string[] -- all candidate URLs including not-selected",
      "queries": "string[]",
      "llm_queries": "string[] -- empty array from canonical callers",
      "search_profile": "object -- executed search_profile payload (status: 'executed')",
      "search_profile_key": "string",
      "search_profile_run_key": "string|null",
      "search_profile_latest_key": "string|null",
      "provider_state": "object -- searchEngineAvailability() result",
      "query_concurrency": "number",
      "internal_satisfied": "boolean",
      "external_search_reason": "string|null",
      "search_attempts": "Array<object>",
      "search_journal": "Array<object>",
      "serp_explorer": "object -- SERP explorer summary with per-query stats"
    }
  }
