  style storagesettings fill:#2d333b,stroke:#3fb950,color:#e0e0e0,stroke-width:2px
  style configHandler fill:#21262d,stroke:#4a90d9,color:#c9d1d9
  style userSettingsSvc fill:#21262d,stroke:#4a90d9,color:#c9d1d9
