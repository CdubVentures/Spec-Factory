  style frontierUrls fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style frontierYields fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style compileWriter fill:#21262d,stroke:#4a90d9,color:#c9d1d9
  style brandRegistryMod fill:#21262d,stroke:#4a90d9,color:#c9d1d9
