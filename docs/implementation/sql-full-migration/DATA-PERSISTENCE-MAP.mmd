    "lineColor": "#6c757d",
    "secondaryColor": "#16213e",
    "tertiaryColor": "#0f3460",
    "background": "#0d1117",
    "mainBkg": "#161b22",
    "nodeBorder": "#4a90d9",
    "clusterBkg": "#161b22",
    "clusterBorder": "#30363d",
    "titleColor": "#e0e0e0",
    "edgeLabelBackground": "#0d1117",
    "nodeTextColor": "#e0e0e0"
  },
  "flowchart": {
    "nodeSpacing": 40,
    "rankSpacing": 50,
    "curve": "basis",
    "padding": 15
  }
}}%%

flowchart TB

  title["<b>SPEC FACTORY DATA PERSISTENCE MAP</b><br/><i>Post-Wave 4 — All hot-path state in SQL  |  Audited 2026-03-27</i>"]
  style title fill:#0d1117,stroke:none,color:#58a6ff,font-size:20px

  %% ===== LEGEND =====
  subgraph LEGEND["LEGEND"]
    direction LR
    L1["JSON File (boundary only)"]
    L2[("SQLite Table (primary)")]
    L3{{"NDJSON (fallback only)"}}
    L4["Eliminated"]
    L1 ~~~ L2 ~~~ L3 ~~~ L4
  end
  style LEGEND fill:#161b22,stroke:#30363d,color:#8b949e
  style L1 fill:#2d333b,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
  style L2 fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style L3 fill:#2d333b,stroke:#d29922,color:#e0e0e0,stroke-width:2px
  style L4 fill:#da3633,stroke:#f85149,color:#fff,stroke-width:2px

  %% ============================================================
  %%  SECTION 1: RUN STATE (Waves 1-3)
  %% ============================================================
  subgraph RUN_STATE["RUN STATE  (SQL primary — Waves 1-3)"]
    direction TB
    rba["runtimeBridgeArtifacts.js"]
    rbeh["runtimeBridgeEventHandlers.js"]

    runjson["run.json<br/><i>boundary only (start + end)</i>"]
    needsetjson["needset.json<br/><i>boundary only (start)</i>"]
    searchprofilejson["search_profile.json<br/><i>boundary only (start)</i>"]
    screencastjson["runtime_screencast/*.json<br/><i>per-worker screenshot frames</i>"]

    runs_sql[("runs<br/><i>SQL primary — Wave 2</i>")]
    bridge_sql[("bridge_events<br/><i>SQL only — Wave 1</i>")]
    artifacts_sql[("run_artifacts<br/><i>SQL primary — Wave 3<br/>needset + search_profile + brand_resolution</i>")]

    rba -->|"SQL mid-run"| runs_sql
    rba -->|"SQL mid-run"| artifacts_sql
    rba -->|"JSON at boundary"| runjson
    rba -->|"JSON at boundary"| needsetjson
    rba -->|"JSON at boundary"| searchprofilejson
    rba -->|"WRITE"| screencastjson
    rbeh -->|"INSERT"| bridge_sql

    killed1["run_events.ndjson KILLED"]
    killed2["mid-run run.json overwrites KILLED"]
    killed3["mid-run needset/profile rewrites KILLED"]
  end
  style RUN_STATE fill:#0d1117,stroke:#238636,color:#e0e0e0,stroke-width:2px

  subgraph RUN_READERS["Run State Readers"]
    direction TB
    runlistbuilder["runListBuilder.js  READ runs SQL + run.json fallback"]
    runtimeops["runtimeOpsRoutes.js  READ run_artifacts SQL"]
    relocationSvc["runDataRelocationService.js  READ all + relocate"]
  end

  runs_sql --> runlistbuilder
  artifacts_sql --> runtimeops

  %% ============================================================
  %%  SECTION 2: SETTINGS
  %% ============================================================
  subgraph SETTINGS["SETTINGS  (JSON only — not yet migrated)"]
    direction TB
    usersettings["user-settings.json<br/><i>all user prefs (schema v2):<br/>storage, LLM, runtime knobs</i>"]
    settingssnapshot["{runId}-settings.json<br/><i>frozen config for run</i>"]
    storagesettings["storage-settings.json<br/><i>legacy compat copy</i>"]

    configHandler["configStorageSettingsHandler.js"]
    userSettingsSvc["userSettingsService.js"]

    configHandler -->|"WRITE"| usersettings
    configHandler -->|"WRITE"| storagesettings
    userSettingsSvc -->|"READ/WRITE"| usersettings
  end
  style SETTINGS fill:#0d1117,stroke:#f0883e,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 3: BILLING & TELEMETRY (Wave 4)
  %% ============================================================
  subgraph BILLING["BILLING & TELEMETRY  (SQL primary — Wave 4)"]
    direction TB
    costLedger["costLedger.js"]
    metricsWriter["metricsWriter.js"]
    traceWriter["runtimeTraceWriter.js"]

    billing_sql[("billing_entries<br/><i>SQL only — Wave 4</i>")]
    metrics_sql[("metrics<br/><i>SQL primary — Wave 4</i>")]
    metricslog{{"_runtime/metrics.jsonl<br/><i>NDJSON fallback only<br/>(when specDb is null)</i>"}}
    llmtraces["traces/{section}/{prefix}.json<br/><i>LLM call traces (ring buffer)</i>"]

    costLedger -->|"INSERT SQL only"| billing_sql
    metricsWriter -->|"INSERT SQL primary"| metrics_sql
    metricsWriter -.->|"NDJSON fallback"| metricslog
    traceWriter -->|"WRITE"| llmtraces

    killed4{{"_billing/ledger/*.jsonl KILLED"}}
  end
  style BILLING fill:#0d1117,stroke:#238636,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 4: SPEC DATABASE (48 tables total)
  %% ============================================================
  subgraph SPECDB["SPEC DATABASE  (.specfactory_tmp/{cat}/spec.sqlite  -  48 tables)"]
    direction TB
    candidates[("candidates + candidate_reviews<br/><i>evidence-backed value proposals</i>")]
    components[("component_identity + aliases + values<br/><i>canonical component definitions</i>")]
    items[("item_field_state + links<br/><i>per-product extracted values</i>")]
    enums[("enum_lists + list_values<br/><i>allowed categorical values</i>")]
    reviews[("key_review_state + runs + audit<br/><i>AI/human decisions + audit trail</i>")]
    queue[("product_queue + product_runs + artifacts<br/><i>queue management + run history</i>")]
    sources[("source_registry + assertions + evidence_refs<br/><i>evidence lineage</i>")]
    intel[("source_intel_domains + brands + paths + corpus<br/><i>domain/brand reputation</i>")]
    routematrix[("llm_route_matrix<br/><i>per-field extraction routing</i>")]
    learningdb[("learning_profiles + category_brain<br/><i>per-brand metrics + artifacts</i>")]
    wave_tables[("Wave 1-4: bridge_events + runs +<br/>run_artifacts + billing_entries + metrics")]
  end
  style SPECDB fill:#0d1117,stroke:#1f6feb,color:#e0e0e0,stroke-width:3px

  %% ============================================================
  %%  SECTION 5: FRONTIER DB
  %% ============================================================
  subgraph FRONTIER["FRONTIER DB  (SQLite  -  query/URL learning)"]
    direction TB
    frontierQueries[("queries<br/><i>query_hash, product_id, results</i>")]
    frontierUrls[("urls<br/><i>canonical_url, fetch_count, cooldown</i>")]
    frontierYields[("yields<br/><i>url, field_key, confidence</i>")]
  end
  style FRONTIER fill:#0d1117,stroke:#1f6feb,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 6: CATALOG & FIELD AUTHORITY
  %% ============================================================
  subgraph CATALOG["CATALOG & FIELD AUTHORITY  (category_authority/ — immutable artifacts)"]
    direction TB
    compileWriter["compileOutputWriter.js"]
    brandRegistryMod["brandRegistry.js"]

    fieldrules["field_rules.json + field_rules.full.json"]
    knownvalues["_generated/known_values.json"]
    uicatalog["_generated/ui_field_catalog.json"]
    componentdb["_generated/component_db/*.json"]
    compilereport["_generated/_compile_report.json"]
    brandregistryjson["_global/brand_registry.json"]
    suggestions["_suggestions/enums.json + components.json"]

    compileWriter -->|"WRITE"| fieldrules
    compileWriter -->|"WRITE"| knownvalues
    compileWriter -->|"WRITE"| uicatalog
    compileWriter -->|"WRITE"| componentdb
    compileWriter -->|"WRITE"| compilereport
    compileWriter -->|"WRITE"| suggestions
    brandRegistryMod -->|"READ/WRITE"| brandregistryjson
  end
  style CATALOG fill:#0d1117,stroke:#e3b341,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 7: EXPORT ARTIFACTS
  %% ============================================================
  subgraph EXPORT["EXPORT ARTIFACTS  (per-product, write-once per run)"]
    direction TB
    exporter["exporter.js"]
    finalExporter["finalExporter.js"]

    specjson["spec.json  -  final extracted spec"]
    summaryjson["summary.json  -  validation summary"]
    provenancejson["provenance.json  -  data sources"]
    trafficjson["traffic_light.json  -  confidence scores"]
    evidencejson["evidence/evidence_pack.json"]
    candidatesjson["extracted/{host}/candidates.json"]
    ldjsonjson["raw/pages/{host}/ldjson.json"]
    runhistory{{"final/{product}/history/runs.jsonl"}}

    exporter -->|"WRITE"| specjson
    exporter -->|"WRITE"| summaryjson
    exporter -->|"WRITE"| provenancejson
    exporter -->|"WRITE"| trafficjson
    exporter -->|"WRITE"| evidencejson
    exporter -->|"WRITE"| candidatesjson
    exporter -->|"WRITE"| ldjsonjson
    finalExporter -->|"APPEND"| runhistory
  end
  style EXPORT fill:#0d1117,stroke:#f778ba,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 8: LLM CACHE (dual-path)
  %% ============================================================
  subgraph LLMCACHE["LLM CACHE  (dual-path)"]
    direction TB
    llmCacheModule["llmCache.js"]
    llmcachejson["llm_cache/{sha256}.json<br/><i>file-based fallback</i>"]
    llmcachesql[("llm_cache table<br/><i>SQL preferred</i>")]
    llmCacheModule -->|"fallback"| llmcachejson
    llmCacheModule -->|"preferred"| llmcachesql
  end
  style LLMCACHE fill:#0d1117,stroke:#d29922,color:#e0e0e0,stroke-width:2px

  %% ============================================================
  %%  SECTION 9: LEARNING (dual-path)
  %% ============================================================
  subgraph LEARNING["LEARNING  (dual-path, migrating to SQL)"]
    direction TB
    learningjson["_learning/{cat}/profiles/*.json"]
    brainjson["_learning/{cat}/{artifact}.json<br/><i>field_lexicon, constraints,<br/>query_templates, etc.</i>"]
    learningTarget[("learning_profiles + category_brain<br/><i>SQL target</i>")]
    learningjson -.->|"migrating"| learningTarget
    brainjson -.->|"migrating"| learningTarget
  end
  style LEARNING fill:#0d1117,stroke:#d29922,color:#e0e0e0,stroke-width:2px

  %% ===== Node styles =====
  style rba fill:#21262d,stroke:#4a90d9,color:#c9d1d9
  style rbeh fill:#21262d,stroke:#4a90d9,color:#c9d1d9
  style runjson fill:#2d333b,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
  style needsetjson fill:#2d333b,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
  style searchprofilejson fill:#2d333b,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
  style screencastjson fill:#2d333b,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
