  style runtimeeventslog fill:#2d333b,stroke:#a371f7,color:#e0e0e0,stroke-width:2px
  style metricslog fill:#2d333b,stroke:#a371f7,color:#e0e0e0,stroke-width:2px
  style monthlyrollup fill:#2d333b,stroke:#a371f7,color:#e0e0e0,stroke-width:2px
  style llmtraces fill:#2d333b,stroke:#a371f7,color:#e0e0e0,stroke-width:2px
  style billingdb fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style runtimeeventsdb fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style llmcachedb fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style candidates fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style components fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
  style items fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
