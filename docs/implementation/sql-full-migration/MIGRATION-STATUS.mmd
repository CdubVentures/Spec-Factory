flowchart TB

  title["<b>SQL MIGRATION STATUS</b><br/><i>JSON to SQL SSOT Roadmap  |  Audit 2026-03-26</i>"]
  style title fill:#0d1117,stroke:none,color:#58a6ff,font-size:20px

  %% ==========================================
  %%  ALREADY IN SQL
  %% ==========================================
  subgraph DONE["ALREADY IN SQL  (SSOT)"]
    direction TB
    d1[("candidates + candidate_reviews")]
    d2[("component_identity + aliases + values")]
    d3[("item_field_state + component_links + list_links")]
    d4[("enum_lists + list_values")]
    d5[("key_review_state + runs + audit")]
    d6[("product_queue + product_runs + artifacts")]
    d7[("source_registry + assertions + evidence_refs")]
    d8[("source_intel_domains + brands + paths + corpus")]
    d9[("llm_route_matrix")]
    d10[("curation_suggestions + component_review_queue")]
    d11[("audit_log")]
    df1[("frontierDb: queries + urls + yields")]
  end
  style DONE fill:#0d1117,stroke:#238636,color:#3fb950,stroke-width:3px
  style d1 fill:#238636,stroke:#3fb950,color:#fff
  style d2 fill:#238636,stroke:#3fb950,color:#fff
  style d3 fill:#238636,stroke:#3fb950,color:#fff
  style d4 fill:#238636,stroke:#3fb950,color:#fff
