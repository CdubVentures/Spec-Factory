flowchart TB

  title["<b>PIPELINE DATA FLOW  |  Run Lifecycle Start-to-Archive</b><br/><i>Post-Wave 5.5 — SQL + run-summary.json  |  2026-03-27</i>"]
  style title fill:#0d1117,stroke:none,color:#58a6ff,font-size:22px

  %% ===== PHASE 0: INITIALIZATION =====
  subgraph P0["PHASE 0  INITIALIZATION"]
    direction LR
    p0_start(["processRuntime.startProcess()"])
    p0_runsql[("UPSERT runs (slim 14 cols)<br/><i>status: starting</i>")]
    p0_artifacts[("INSERT run_artifacts<br/><i>needset + search_profile baseline</i>")]
    p0_ws["WS broadcast<br/><i>process-status: running</i>"]
    p0_nofiles["NO JSON files written<br/><i>run.json, needset.json, search_profile.json KILLED</i>"]

    p0_start --> p0_runsql
    p0_start --> p0_artifacts
    p0_start --> p0_ws
    p0_start --> p0_nofiles
  end
  style P0 fill:#0d1117,stroke:#58a6ff,color:#e0e0e0,stroke-width:2px
  style p0_start fill:#238636,stroke:#3fb950,color:#fff
  style p0_runsql fill:#238636,stroke:#3fb950,color:#fff
  style p0_artifacts fill:#238636,stroke:#3fb950,color:#fff
  style p0_ws fill:#21262d,stroke:#8b949e,color:#c9d1d9
  style p0_nofiles fill:#da3633,stroke:#f85149,color:#fff

  %% ===== PHASES 1-7: SEARCH + DISCOVERY =====
  subgraph P17["PHASES 1-7  SEARCH + DISCOVERY"]
    direction LR
    p1_needset["NeedSet + Brand<br/><i>LLM calls</i>"]
    p2_search["Search Execution<br/><i>Bing/Google</i>"]
    p3_serp["SERP Selector<br/><i>LLM triage</i>"]
    p4_domain["Domain Classifier<br/><i>URL ranking</i>"]

    p17_sql[("SQL writes:<br/>bridge_events, run_artifacts,<br/>billing_entries, runs (counters)")]

    p1_needset --> p2_search --> p3_serp --> p4_domain
    p4_domain --> p17_sql
  end
  style P17 fill:#0d1117,stroke:#a371f7,color:#e0e0e0,stroke-width:2px
  style p1_needset fill:#21262d,stroke:#d29922,color:#c9d1d9
  style p2_search fill:#21262d,stroke:#d29922,color:#c9d1d9
  style p3_serp fill:#21262d,stroke:#d29922,color:#c9d1d9
  style p4_domain fill:#21262d,stroke:#3fb950,color:#c9d1d9
  style p17_sql fill:#238636,stroke:#3fb950,color:#fff

  %% ===== PHASE 8: CRAWL =====
  subgraph P8["PHASE 8  CRAWL"]
    direction LR
    p8_batch["processBatch()<br/><i>concurrent workers</i>"]
    p8_frontier[("frontierDb.urls")]
    p8_events[("bridge_events<br/><i>fetch events</i>")]
    p8_runs[("runs<br/><i>counters++</i>")]
    p8_binaries["Content-addressed<br/><i>page.html.gz, screenshot</i>"]

    p8_batch --> p8_frontier
    p8_batch --> p8_events
    p8_batch --> p8_runs
    p8_batch --> p8_binaries
  end
  style P8 fill:#0d1117,stroke:#f0883e,color:#e0e0e0,stroke-width:2px
  style p8_batch fill:#21262d,stroke:#f0883e,color:#c9d1d9
  style p8_frontier fill:#1f6feb,stroke:#58a6ff,color:#fff
  style p8_events fill:#238636,stroke:#3fb950,color:#fff
  style p8_runs fill:#238636,stroke:#3fb950,color:#fff
  style p8_binaries fill:#2d333b,stroke:#3fb950,color:#e0e0e0

  %% ===== PHASE 9: PARSE + INDEX =====
  subgraph P9["PHASE 9  PARSE + INDEX + EXPORT"]
    direction LR
    p9_parse["extractCandidates()"]
    p9_specdb[("candidates, item_field_state,<br/>source_registry, evidence")]
    p9_export["spec.json, summary.json,<br/>provenance.json"]
    p9_billing[("billing_entries<br/><i>SQL only</i>")]

    p9_parse --> p9_specdb
    p9_parse --> p9_export
    p9_parse --> p9_billing
  end
  style P9 fill:#0d1117,stroke:#f778ba,color:#e0e0e0,stroke-width:2px
  style p9_parse fill:#21262d,stroke:#f778ba,color:#c9d1d9
  style p9_specdb fill:#1f6feb,stroke:#58a6ff,color:#fff
  style p9_export fill:#2d333b,stroke:#f778ba,color:#e0e0e0
  style p9_billing fill:#238636,stroke:#3fb950,color:#fff

  %% ===== PHASE 10: FINALIZE + ARCHIVE =====
  subgraph P10["PHASE 10  FINALIZE + ARCHIVE"]
    direction LR
    p10_summary["WRITE run-summary.json<br/><i>schema_version + telemetry:<br/>meta, events, llm_agg, observability</i>"]
    p10_runsql[("UPDATE runs<br/><i>status: completed</i>")]
    p10_purge["PURGE bridge_events<br/><i>captured in run-summary.json</i>"]
    p10_relocate["relocateRunData()<br/><i>bundle → LOCAL or S3</i>"]
    p10_dbupdate[("product_runs<br/><i>storage_state, s3_key</i>")]

    p10_summary --> p10_runsql --> p10_purge --> p10_relocate --> p10_dbupdate
  end
  style P10 fill:#0d1117,stroke:#238636,color:#e0e0e0,stroke-width:2px
  style p10_summary fill:#238636,stroke:#3fb950,color:#fff,stroke-width:3px
  style p10_runsql fill:#238636,stroke:#3fb950,color:#fff
  style p10_purge fill:#da3633,stroke:#f85149,color:#fff
  style p10_relocate fill:#21262d,stroke:#238636,color:#c9d1d9
  style p10_dbupdate fill:#1f6feb,stroke:#58a6ff,color:#fff

  %% ===== FLOW =====
  P0 --> P17
  P17 --> P8
  P8 --> P9
  P9 --> P10
