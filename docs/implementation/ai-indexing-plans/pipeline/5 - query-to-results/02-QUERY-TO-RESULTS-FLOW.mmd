flowchart LR
  A["Selected query strings<br/>queries + executionQueryLimit"] --> B

  subgraph Q["PHASE 1: EXECUTION CONTROLS"]
    direction TB
    B["Execution entry inside discoverCandidateSources()"]
    C["resultsPerQuery = config.discoveryResultsPerQuery<br/>queryConcurrency = config.discoveryQueryConcurrency"]
    D["providerState = searchProviderAvailability()<br/>google/bing/dual are SearXNG-backed"]
    E["Optional internalFirst branch"]
    B --> C --> D --> E
  end

  subgraph X["PHASE 2: QUERY EXECUTION BRANCHES"]
    direction TB
    X0{"Internet provider ready?"}
    X1["Frontier query cache reuse<br/>reason_code = frontier_query_cache"]
    X2["searchSourceCorpus()<br/>provider = internal"]
    X3["runSearchProviders()<br/>SearXNG attempt plan by provider mode"]
    X4["Zero results -> buildQueryPlanFallbackResults()<br/>provider = plan_fallback"]
    X5["No provider and rawResults still empty<br/>buildPlanOnlyResults()<br/>provider = plan"]
    X1 --> X2
    X0 -->|yes| X1 --> X3 --> X4
    X0 -->|no| X5
  end

  subgraph Y["PHASE 3: RAW AGGREGATION + SIDE EFFECTS"]
    direction TB
    Y1["Append providerResults into rawResults"]
    Y2["Append attempt rows into searchAttempts"]
    Y3["Append journal rows into searchJournal"]
    Y4["Internet branch side effects<br/>frontierDb.recordQuery()<br/>query-index NDJSON<br/>optional runtime trace JSON"]
    Y1 --> Y2 --> Y3 --> Y4
  end

  subgraph Z["PHASE 4: SERP DEDUPE"]
    direction TB
    Z1["dedupeSerpResults()"]
    Z2["normalizeUrl()<br/>lowercase host<br/>strip tracking params<br/>normalize trailing slash"]
    Z3["Keep best-ranked row per canonical URL<br/>merge seen_by_providers + seen_in_queries"]
    Z4["Emit dedupedResults + dedupeStats"]
    Z1 --> Z2 --> Z3 --> Z4
  end

  subgraph O["PHASE 5: OUTPUT BOUNDARY"]
    direction TB
    O1["Outputs to next phase<br/>dedupedResults<br/>searchAttempts<br/>searchJournal"]
    O2["Execution state carried forward<br/>providerState<br/>internalSatisfied<br/>externalSearchReason"]
    O1 --> O2
  end

  Q --> X --> Y --> Z --> O
