flowchart TD
  START["Schema 4 search_plan_handoff<br/>OR old-path buildSearchProfile()"] --> GATE{"enableSchema4SearchPlan<br/>AND handoff.queries.length > 0?"}

  %% ─── Schema 4 Adapter Path ───
  GATE -- "YES" --> ADAPT["convertHandoffToExecutionPlan()<br/>queries[] + queryRows[] + selectedQueryRowMap<br/>source = 'schema4'"]

  %% ─── Old Path ───
  GATE -- "NO (old path)" --> OLD["buildSearchProfile() → 7-layer chain<br/>base_template + targeted + llm + uber + extra<br/>dedupeQueryRows() → prioritizeQueryRows()"]

  %% ─── Shared: Identity Guard ───
  ADAPT --> GUARD["enforceIdentityQueryGuard()<br/>brand tokens + model digits + variant guard<br/>reject off-brand/off-model queries"]
  OLD --> GUARD

  GUARD -- "ALL rejected" --> FALLBACK["Fallback → old path<br/>log schema4_guard_rejected_all"]
  FALLBACK --> OLD

  GUARD -- "accepted rows" --> PROFILE["Write searchProfilePlanned<br/>status=planned<br/>selected_queries + query_guard + query_reject_log"]

  %% ─── Execution ───
  subgraph EXEC["PHASE 3: QUERY EXECUTION"]
    direction TB
    E1["Provider diagnostics<br/>searchProviderAvailability()"]
    E2{"discoveryInternalFirst?"}
    E3["Internal-first: frontier cache + corpus search<br/>check if required fields satisfied"]
    E4["Internet search: SearXNG<br/>concurrency=queryConcurrency<br/>frontier check per query"]
    E5["Plan-only fallback<br/>manufacturer URLs from domain"]
    E1 --> E2
    E2 -- "YES" --> E3
    E3 --> E4
    E2 -- "NO" --> E4
    E4 -- "0 results + no provider" --> E5
  end

  PROFILE --> EXEC

  %% ─── Classification + Admission ───
  subgraph CLASS["PHASE 4: CLASSIFY + ADMIT"]
    direction TB
    C1["dedupeSerpResults()<br/>cross-provider dedup"]
    C2["classifyUrlCandidate() per result<br/>host, tier, role, doc_kind_guess<br/>identity_match_level, variant_guard_hit, multi_model_hint"]
    C3["Hard rejects<br/>non_https, denied_host, url_cooldown<br/>brand_mismatch, low_relevance"]
    C4["Soft exclusions<br/>forum_subdomain, forum_classification<br/>sibling_model_page, non_manufacturer_multi_model"]
    C1 --> C2 --> C3 --> C4
  end

  EXEC --> CLASS

  %% ─── Rerank + Triage ───
  subgraph TRIAGE["PHASE 5: RERANK + TRIAGE"]
    direction TB
    T1["rerankSearchResults()<br/>deterministic scoring (always runs)<br/>14-weight composite: identity + tier + field affinity + diversity"]
    T2{"LLM triage gate?<br/>serpTriageEnabled<br/>+ API key for plan role"}
    T3["rerankSerpResults() LLM call<br/>reason=uber_serp_reranker, role=plan<br/>keep/drop per URL with reason+score"]
    T4["Deterministic threshold fallback<br/>score >= serpTriageMinScore<br/>cap = serpTriageMaxUrls"]
    T1 --> T2
    T2 -- "YES" --> T3
    T2 -- "NO" --> T4
    T3 -- "error/empty" --> T4
  end

  CLASS --> TRIAGE

  %% ─── Outputs ───
  subgraph OUT["PHASE 6: OUTPUTS"]
    direction TB
    O1["Write searchProfileFinal<br/>status=executed<br/>query_stats + serp_explorer"]
    O2["Split discovered URLs<br/>approvedUrls → planner.enqueue()<br/>candidateUrls → planner.seedCandidates()"]
    O3["Write discovery + candidate payloads to S3"]
    O1 --> O2 --> O3
  end

  TRIAGE --> OUT

  %% ─── Styling ───
  classDef s4class fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20
  classDef oldclass fill:#fff3e0,stroke:#ef6c00,color:#e65100
  classDef gateclass fill:#e3f2fd,stroke:#1565c0,color:#0d47a1
  classDef llmclass fill:#fce4ec,stroke:#c62828,color:#b71c1c

  class ADAPT s4class
  class OLD,FALLBACK oldclass
  class GATE,GUARD gateclass
  class T3 llmclass
