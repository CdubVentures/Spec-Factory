%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '16px', 'fontFamily': 'Segoe UI', 'primaryColor': '#1565c0', 'primaryTextColor': '#fff', 'primaryBorderColor': '#0d47a1', 'lineColor': '#444', 'secondaryColor': '#e3f2fd', 'tertiaryColor': '#bbdefb'}}}%%

flowchart LR
    subgraph PHASE1["PHASE 1: SOURCE FILTERING + NORMALIZATION"]
        direction TB

        subgraph FILTER["Source Filtering"]
            direction TB
            F1["<b>resolveIdentityLabel()</b><br/>per source"]
            F2["<b>matched:</b> match=true<br/><b>possible:</b> score ≥ 0.4<br/><b>different:</b> conflicts or low<br/><b>unknown:</b> null/missing"]
            F3["<b>Two-condition gate:</b><br/>label ∈ {matched, possible}<br/>AND majorConflicts === 0"]
            F4["<b>Rejected sources:</b><br/>'different' → excluded<br/>'unknown' → excluded<br/>anchor conflicts → excluded"]
            F1 --> F2 --> F3 --> F4
        end

        subgraph SEED["Identity Seeding"]
            direction TB
            S1["<b>From identityLock:</b><br/>fields.id = productId<br/>fields.brand = lock.brand<br/>fields.model = lock.model"]
            S2["<b>fields.base_model</b><br/>= lock.model<br/><b>fields.category</b> = category<br/><b>fields.sku</b> = lock.sku"]
            S3["<b>PASS_EXEMPT_FIELDS:</b><br/>id, brand, model,<br/>base_model, category, sku<br/>pass_target = 0"]
            S1 --> S2 --> S3
        end

        subgraph NORMALIZE["Candidate Normalization"]
            direction TB
            N1["<b>canonicalValue(field, value)</b>"]
            N2["<b>polling_rate:</b> parse nums,<br/>round, dedup, sort desc<br/><b>NUMERIC:</b> parseNumber,<br/>round to 2dp"]
            N3["<b>LIST:</b> split, normalize<br/>whitespace, join ', '<br/><b>Other:</b> normalize<br/>whitespace, trim"]
            N4["<b>Returns:</b><br/>{ display, key }<br/>key = lowercase for<br/>cluster grouping"]
            N1 --> N2 --> N3 --> N4
        end

        subgraph COLLECT["Candidate Collection"]
            direction TB
            C1["<b>Per usable source:</b><br/>for each fieldCandidate"]
            C2["<b>Score per candidate:</b><br/>tierWeight × methodWeight"]
            C3["<b>resolveCitation()</b><br/>snippet lookup from<br/>llmEvidencePack"]
            C4["<b>→ byField Map</b><br/>{ field: [rows...] }<br/>each row: value, tier,<br/>method, score, citation"]
            C1 --> C2 --> C3 --> C4
        end

        FILTER --> SEED --> NORMALIZE --> COLLECT
    end

    subgraph PHASE2["PHASE 2: CLUSTERING + ACCEPTANCE"]
        direction TB

        subgraph CLUSTER["Cluster Candidates"]
            direction TB
            CL1["<b>clusterCandidates(rows)</b><br/>group by clusterKey"]
            CL2["<b>Per cluster:</b><br/>score += tierW × methodW<br/>(approved domains only)<br/>track domain sets"]
            CL3["<b>Output per cluster:</b><br/>key, display, score,<br/>domainCount,<br/>approvedDomainCount,<br/>instrumentedDomainCount"]
            CL1 --> CL2 --> CL3
        end

        subgraph WEIGHTS["Weight Tables"]
            direction TB
            W1["<b>TIER_WEIGHT:</b><br/>T1: 1.0, T2: 0.8,<br/>T3: 0.45, Other: 0.4"]
            W2["<b>METHOD_WEIGHT (top):</b><br/>network_json: 1.0<br/>adapter_api: 0.95<br/>pdf_table: 0.95<br/>html_table/json_ld: 0.9"]
            W3["<b>METHOD_WEIGHT (mid):</b><br/>microdata: 0.88<br/>embedded_state: 0.85<br/>pdf: 0.82<br/>opengraph: 0.80"]
            W4["<b>METHOD_WEIGHT (low):</b><br/>dom: 0.40<br/>llm_extract: 0.20 (base)<br/><b>LLM tier-dependent:</b><br/>T1: 0.6, T2: 0.4,<br/>T3: 0.2, T4: 0.15"]
            W1 --> W2 --> W3 --> W4
        end

        subgraph RANK["Cluster Ranking"]
            direction TB
            R1["<b>selectBestCluster()</b>"]
            R2["<b>Sort priority:</b><br/>1. approvedDomainCount desc<br/>2. score desc<br/>3. display alphabetical"]
            R3["<b>applyPolicyBonus()</b><br/>tiebreaker +0.3 for<br/>best_evidence /<br/>prefer_deterministic /<br/>prefer_llm / prefer_latest"]
            R4["<b>Returns:</b><br/>{ best, second }"]
            R1 --> R2 --> R3 --> R4
        end

        subgraph ACCEPT["Acceptance Logic"]
            direction TB
            A1["<b>Weighted majority:</b><br/>best.score ≥ second × 1.1"]
            A2["<b>STRICT:</b><br/>approvedDomains ≥ 2<br/>+ weighted majority"]
            A3["<b>RELAXED:</b><br/>+ T1 manufacturer<br/>+ credible domain (T≤2)<br/>NOT for INSTRUMENTED"]
            A4["<b>INSTRUMENTED:</b><br/>strict + ≥ 3<br/>instrumented domains<br/>(rtings, techpowerup, labs)"]
            A5["<b>Result:</b><br/>accepted → best.display<br/>rejected → 'unk'"]
            A1 --> A2 --> A3 --> A4 --> A5
        end

        CLUSTER --> WEIGHTS --> RANK --> ACCEPT
    end

    subgraph PHASE3["PHASE 3: POST-CONSENSUS REDUCERS"]
        direction TB

        subgraph CONFIDENCE["Confidence + Pass Targets"]
            direction TB
            CO1["<b>Per-field confidence:</b><br/>base + majority + score"]
            CO2["<b>base:</b><br/>≥2 approved → 0.70<br/>1 approved → 0.25<br/>0 approved → 0.00"]
            CO3["<b>+ majority bonus:</b> 0.20<br/><b>+ score bonus:</b><br/>min(0.10, score/10)"]
            CO4["<b>Pass targets:</b><br/>exempt: 0<br/>normal: 2<br/>commonly_wrong: 4<br/><b>Agreement score:</b><br/>best/(best+second) avg"]
            CO1 --> CO2 --> CO3 --> CO4
        end

        subgraph SELECTION["Selection Policy Reducers"]
            direction TB
            SP1["<b>applySelectionPolicyReducers()</b><br/>object-form policies"]
            SP2["<b>Single value:</b><br/>→ use directly"]
            SP3["<b>Within tolerance_ms:</b><br/>→ median of sorted values"]
            SP4["<b>Exceeds tolerance:</b><br/>→ 'unk' (conflicting)"]
            SP1 --> SP2 --> SP3 --> SP4
        end

        subgraph LISTUNION["List Union Reducers"]
            direction TB
            LU1["<b>applyListUnionReducers()</b><br/>item_union from field rules"]
            LU2["<b>set_union:</b><br/>winner items first,<br/>then unique from others<br/>sorted by tier/score"]
            LU3["<b>ordered_union:</b><br/>same merge, preserves<br/>internal item order"]
            LU4["<b>Guards:</b><br/>≥ 2 approved candidates<br/>winner not unk/n/a<br/>dedup by lowercase"]
            LU1 --> LU2 --> LU3 --> LU4
        end

        subgraph COREDEEP["Core/Deep Gates"]
            direction TB
            CD1["<b>applyCoreDeepGates()</b><br/>only if enableCoreDeepGates"]
            CD2["<b>core_fact:</b><br/>T1-2: accepted<br/>T3 + corroboration≥2: OK<br/>T3 without: rejected<br/>T4+: always rejected"]
            CD3["<b>deep_claim:</b><br/>all tiers accepted"]
            CD4["<b>Deep numeric cluster:</b><br/>median, range, outliers<br/>(> 2× or < 0.5× median)"]
            CD1 --> CD2 --> CD3 --> CD4
        end

        CONFIDENCE --> SELECTION --> LISTUNION --> COREDEEP
    end

    subgraph PHASE4["PHASE 4: OUTPUT + QUALITY GATE"]
        direction TB

        subgraph PROVENANCE["Provenance Construction"]
            direction TB
            P1["<b>Per-field provenance:</b>"]
            P2["<b>value, anchor_locked,</b><br/>confirmations,<br/>approved_confirmations,<br/>instrumented_confirmations"]
            P3["<b>pass_target,</b><br/>meets_pass_target,<br/>weighted_majority,<br/>confidence: 0-1"]
            P4["<b>evidence[]:</b><br/>url, host, tier, method,<br/>snippet_id, snippet_hash,<br/>quote, quote_span,<br/>retrieved_at"]
            P1 --> P2 --> P3 --> P4
        end

        subgraph TRAFFIC["Traffic Light"]
            direction TB
            TL1["<b>buildTrafficLight()</b><br/>per-field color"]
            TL2["<b>GREEN:</b> component_db<br/>or tier 1 (manufacturer)"]
            TL3["<b>YELLOW:</b> tier 2<br/>(lab / database)"]
            TL4["<b>RED:</b> tier 3+ or<br/>no evidence or 'unk'"]
            TL1 --> TL2 --> TL3 --> TL4
        end

        subgraph QUALITY["Quality Gate"]
            direction TB
            QG1["<b>evaluateValidationGate()</b><br/>6 independent checks"]
            QG2["<b>1.</b> identity_gate_ok<br/><b>2.</b> identity_confidence ≥ 0.70<br/><b>3.</b> anchor_conflicts === 0"]
            QG3["<b>4.</b> completeness ≥ target<br/><b>5.</b> confidence ≥ target<br/><b>6.</b> critical fields filled"]
            QG4["<b>validated:</b> all 6 pass<br/><b>publishable:</b><br/>validated + no blockers"]
            QG1 --> QG2 --> QG3 --> QG4
        end

        subgraph OUTPUT["Downstream Output"]
            direction TB
            O1["<b>spec.json:</b><br/>{ field: consensus_value }"]
            O2["<b>provenance.json:</b><br/>per-field evidence chain"]
            O3["<b>traffic_light.json:</b><br/>per-field green/yellow/red"]
            O4["<b>summary.json:</b><br/>quality gate + metrics<br/><b>→ publish gate</b><br/><b>→ hypothesis queue</b><br/><b>→ repair system</b>"]
            O1 --> O2 --> O3 --> O4
        end

        PROVENANCE --> TRAFFIC --> QUALITY --> OUTPUT
    end

    PHASE1 ==>|"usable sources +<br/>normalized candidates"| PHASE2
    PHASE2 ==>|"accepted values +<br/>best clusters"| PHASE3
    PHASE3 ==>|"reduced fields +<br/>gated provenance"| PHASE4

    style PHASE1 fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style PHASE2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:3px
    style PHASE3 fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style PHASE4 fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px
    style FILTER fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style SEED fill:#e0f7fa,stroke:#00838f,stroke-width:1px
    style NORMALIZE fill:#fff8e1,stroke:#f9a825,stroke-width:1px
    style COLLECT fill:#efebe9,stroke:#5d4037,stroke-width:1px
    style CLUSTER fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style WEIGHTS fill:#e0f7fa,stroke:#00838f,stroke-width:1px
    style RANK fill:#ede7f6,stroke:#512da8,stroke-width:2px
    style ACCEPT fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style CONFIDENCE fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style SELECTION fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style LISTUNION fill:#e0f7fa,stroke:#00838f,stroke-width:1px
    style COREDEEP fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    style PROVENANCE fill:#ede7f6,stroke:#512da8,stroke-width:2px
    style TRAFFIC fill:#fff8e1,stroke:#f9a825,stroke-width:2px
    style QUALITY fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style OUTPUT fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px
