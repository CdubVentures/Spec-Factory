{
  "_doc": "Stage 04 Search Planner output returned by runSearchPlanner().",
  "validated_against": "2026-03-20",
  "top_level_keys": [
    "enhancedRows",
    "source"
  ],
  "enhancedRows": {
    "type": "array of row objects",
    "count": "same length as input searchProfileBase.query_rows",
    "row_shape": {
      "query": "possibly LLM-rewritten query string",
      "hint_source": "original_llm when enhanced, original value when fallback",
      "original_query": "pre-enhancement query (only present on LLM-enhanced rows)",
      "tier": "seed | group_search | key_search (passthrough, never mutated)",
      "group_key": "string (passthrough)",
      "normalized_key": "string (passthrough)",
      "target_fields": "string[] (passthrough)",
      "doc_hint": "string (passthrough)",
      "domain_hint": "string (passthrough)",
      "repeat_count": "number (Tier 3 only, passthrough)",
      "all_aliases": "string[] (Tier 3 only, passthrough)",
      "domain_hints": "string[] (Tier 3 only, passthrough)",
      "preferred_content_types": "string[] (Tier 3 only, passthrough)",
      "domains_tried_for_key": "string[] (Tier 3 only, passthrough)",
      "content_types_tried_for_key": "string[] (Tier 3 only, passthrough)"
    }
  },
  "source": "llm | deterministic_fallback",
  "runtime_events": {
    "search_plan_generated": "emitted when source is llm and enhancedRows has entries"
  },
  "downstream_consumer": "src/features/indexing/discovery/stages/queryJourney.js"
}
