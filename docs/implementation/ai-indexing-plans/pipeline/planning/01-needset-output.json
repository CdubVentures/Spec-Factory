{
  "_doc": "Actual output shape returned by computeNeedSet().",
  "validated_against": "2026-03-19",
  "schema_version": "needset_output.v2.1",
  "top_level_keys": [
    "schema_version",
    "round",
    "round_mode",
    "identity",
    "fields",
    "planner_seed",
    "sorted_unresolved_keys",
    "run_id",
    "category",
    "product_id",
    "generated_at",
    "total_fields",
    "summary",
    "blockers",
    "focus_fields",
    "bundles",
    "profile_mix",
    "rows",
    "debug"
  ],
  "identity_block": {
    "state": "locked|provisional|conflict|unknown",
    "source_label_state": "matched|possible|different|unknown",
    "manufacturer": "string|null",
    "model": "string|null",
    "confidence": "number",
    "official_domain": "string|null",
    "support_domain": "string|null"
  },
  "field_entry": {
    "field_key": "string",
    "label": "string",
    "group_key": "string|null",
    "required_level": "identity|critical|required|expected|optional",
    "idx": {
      "min_evidence_refs": "number",
      "query_terms": "string[]",
      "domain_hints": "string[]",
      "preferred_content_types": "string[]",
      "tooltip_md": "string|null",
      "aliases": "string[]"
    },
    "state": "accepted|unknown|weak|conflict",
    "value": "any current field value",
    "confidence": "number",
    "effective_confidence": "number",
    "refs_found": "number",
    "min_refs": "number",
    "best_tier_seen": "number|null",
    "pass_target": "number",
    "meets_pass_target": "boolean",
    "exact_match_required": "boolean",
    "need_score": "number",
    "reasons": [
      "missing",
      "conflict",
      "low_conf",
      "min_refs_fail",
      "publish_gate_block"
    ],
    "history": {
      "existing_queries": "string[]",
      "domains_tried": "string[]",
      "host_classes_tried": "string[]",
      "evidence_classes_tried": "string[]",
      "query_count": "number",
      "urls_examined_count": "number",
      "refs_found": "number",
      "no_value_attempts": "number",
      "duplicate_attempts_suppressed": "number",
      "query_modes_tried_for_key": "string[] (V4)"
    },
    "_v4_search_pack": {
      "normalized_key": "string — human-search-safe form of field_key",
      "all_aliases": "string[] — union of display_name, normalized_key, rule.aliases, query_terms",
      "alias_shards": "string[][] — whole-alias-boundary chunks for query construction",
      "search_intent": "string — exact_match|broad (per-key, derived from exact_match_required)",
      "availability": "string — always|expected|sometimes|rare|editorial_only",
      "difficulty": "string — easy|medium|hard",
      "repeat_count": "number — from history.query_count",
      "query_modes_tried_for_key": "string[] — which query patterns were used",
      "domains_tried_for_key": "string[] — alias of history.domains_tried",
      "content_types_tried_for_key": "string[] — alias of history.evidence_classes_tried"
    }
  },
  "sorted_unresolved_keys": "string[] (V4) — unresolved field_keys sorted by availability -> difficulty -> repeat -> need_score -> required_level",
  "planner_seed": {
    "missing_critical_fields": "string[]",
    "unresolved_fields": "string[]",
    "existing_queries": "string[]",
    "current_product_identity": {
      "category": "string",
      "brand": "string",
      "model": "string"
    }
  },
  "backward_compat_sections": [
    "focus_fields",
    "bundles",
    "profile_mix",
    "rows",
    "debug"
  ]
}
