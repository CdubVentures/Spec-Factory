{
  "_doc": "Live inputs to Stage 05 Query Journey.",
  "validated_against": "2026-03-20",
  "owner": "src/features/indexing/discovery/stages/queryJourney.js",
  "upstream_sources": {
    "enhanced_rows": "runSearchPlanner() -> enhanceQueryRows() (LLM-enhanced or deterministic fallback)",
    "host_plan_rows": "buildScoredQueryRowsFromHostPlan() when validatedRegistry is present"
  },
  "inputs": {
    "searchProfileBase": {
      "query_rows": "original deterministic query row objects (for profileQueryRowsByQuery map)",
      "variant_guard_terms": "string[]",
      "query_reject_log": "array"
    },
    "enhancedRows": "tier-tagged rows from Search Planner (same shape as query_rows, possibly with LLM-rewritten query strings)",
    "hostPlanQueryRows": "array of scored host-plan rows or []",
    "variables": {
      "brand": "string",
      "model": "string",
      "variant": "string",
      "category": "string"
    },
    "config": "object",
    "searchProfileCaps": {
      "dedupeQueriesCap": "number"
    },
    "missingFields": "string[]",
    "planningHints": {
      "missingCriticalFields": "string[]",
      "missingRequiredFields": "string[]"
    },
    "effectiveHostPlan": "object|null",
    "categoryConfig": "object",
    "job": "object",
    "runId": "string",
    "logger": "logger|null",
    "storage": "storage adapter",
    "brandResolution": "object|null"
  },
  "derived_caps": {
    "queryLimit": "configInt(config, 'searchProfileQueryCap')",
    "executionQueryLimit": "min(queryLimit, queries.length)"
  },
  "merge_behavior": "Query Journey treats LLM-enhanced and deterministic fallback rows identically. No branching on source."
}
