%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '16px', 'fontFamily': 'Segoe UI', 'primaryColor': '#1565c0', 'primaryTextColor': '#fff', 'primaryBorderColor': '#0d47a1', 'lineColor': '#444', 'secondaryColor': '#e3f2fd', 'tertiaryColor': '#bbdefb'}}}%%

flowchart LR
    subgraph PHASE1["PHASE 1: DETERMINISTIC EXTRACTION"]
        direction TB

        subgraph INPUT["Fetch Result (per URL)"]
            direction TB
            I1["<b>Per-URL payload:</b><br/>html, finalUrl, title,<br/>status, screenshot"]
            I2["<b>Structured captures:</b><br/>ldjsonBlocks[],<br/>embeddedState{},<br/>networkResponses[],<br/>fetchTelemetry"]
            I1 --> I2
        end

        subgraph BUCKETS["Payload Buckets"]
            direction TB
            B1["buildPayloadBuckets()"]
            B2["<b>Bucket 1: JSON-LD</b><br/>ldjsonBlocks[]<br/>(Product, Org, BreadcrumbList)"]
            B3["<b>Bucket 2: Embedded State</b><br/>nextData.props.pageProps<br/>nuxtState.data<br/>apolloState"]
            B4["<b>Bucket 3: Network JSON</b><br/>classification: specs /<br/>variant_matrix / product_payload<br/>+ identity match required"]
            B1 --> B2 --> B3 --> B4
        end

        subgraph FLATTEN["Flatten & Resolve"]
            direction TB
            FL1["<b>flattenObject()</b><br/>recursive depth-8 flattening<br/>→ {path, value} pairs"]
            FL2["<b>pickFieldFromPath()</b><br/>3-tier alias resolution:<br/>exact → alias → substring(8+)"]
            FL3["<b>normalizeByField()</b><br/>polling_rate: sort desc<br/>connection: dual/wireless/wired<br/>numeric: round, boolean: norm"]
            FL4["<b>79 FIELD_ALIASES</b><br/>+ 6 IDENTITY_ALIAS keys<br/>+ HOST_HINT_PATHS per domain"]
            FL1 --> FL2 --> FL3 --> FL4
        end

        subgraph DOM["DOM Extraction"]
            direction TB
            D1["<b>Static DOM (Cheerio)</b><br/>9 cluster selectors<br/>specSignal regex filter<br/>max 12 clusters"]
            D2["<b>Table pair extraction</b><br/>extractTablePairs()<br/>method: html_table"]
            D3["<b>DOM Fallback (regex)</b><br/>9 patterns: weight, length,<br/>width, height, sensor, dpi,<br/>polling_rate, side/middle buttons"]
            D4["<b>HTML Link Extraction</b><br/>sensor_link, switches_link,<br/>encoder_link from <a> tags"]
            D1 --> D2 --> D3 --> D4
        end

        INPUT --> BUCKETS --> FLATTEN --> DOM
    end

    subgraph PHASE2["PHASE 2: ADAPTER + EVIDENCE"]
        direction TB

        subgraph STRUCTURED["Structured Metadata (Sidecar)"]
            direction TB
            SM1["StructuredMetadataClient<br/>POST to :8011/extract/structured"]
            SM2["<b>6 surfaces in order:</b><br/>json_ld → microdata → rdfa<br/>→ microformats → opengraph<br/>→ twitter"]
            SM3["<b>Per node:</b><br/>flatten → identity match<br/>→ field resolve → normalize<br/>threshold: 0.55"]
            SM4["LRU cache: 400 entries<br/>timeout: 2000ms<br/>max items/surface: 250"]
            SM1 --> SM2 --> SM3 --> SM4
        end

        subgraph ADAPTER["Manufacturer Adapter"]
            direction TB
            MA1["<b>Only if role = manufacturer</b>"]
            MA2["<b>1. HTML tables</b><br/>extractTablePairs()<br/>method: html_table"]
            MA3["<b>2. PDF discovery</b><br/>findPdfUrls() + findSupportUrls()<br/>max 4 PDFs, same domain"]
            MA4["<b>3. PDF parsing</b><br/>parsePdfViaPython()<br/>max 60 pages, 5000 pairs<br/>timeout: 120s"]
            MA5["<b>4. OCR (if enabled)</b><br/>scanned PDF detection<br/>min confidence: 0.55<br/>max 8 pages, 1200 pairs"]
            MA1 --> MA2 --> MA3 --> MA4 --> MA5
        end

        subgraph EVIDENCE["Evidence Pack V2"]
            direction TB
            EP1["buildEvidencePackV2()"]
            EP2["<b>18 content types in order:</b><br/>1. Article (1) 2. Definitions (8)<br/>3. Inline KV (30) 4. Windows (24)<br/>5. Tables (8) 6. Spec sections (8)<br/>7. DOM snippet (1) 8. Screenshot (1)"]
            EP3["<b>Structured data:</b><br/>9. Network JSON (20)<br/>10. JSON-LD (12) 11. Microdata (12)<br/>12. RDFa (10) 13. Microformat (10)<br/>14. OpenGraph (1) 15. Twitter (1)<br/>16. Embedded state (6)"]
            EP4["<b>Documents:</b><br/>17. PDF text/KV/table/OCR<br/>18. Deterministic candidates<br/>All snippets: SHA-256 hashed<br/>field_hints: up to 8 per snippet"]
            EP1 --> EP2 --> EP3 --> EP4
        end

        subgraph ARTICLE["Article Extraction"]
            direction TB
            AE1["extractMainArticle()"]
            AE2["<b>Mode: auto</b><br/>Readability (JSDOM) first<br/>heuristic fallback if >500KB<br/>or parse fails"]
            AE3["<b>Quality scoring (0-100):</b><br/>chars: +28(800+) +16(400+)<br/>words: +26(160+) +14(90+)<br/>headings: +14(2+)<br/>title match: +10<br/>dup ratio: +12(≤0.2) -12(≥0.55)"]
            AE4["<b>Gates:</b><br/>minScore: 45, minChars: 700<br/>maxChars: 60,000"]
            AE1 --> AE2 --> AE3 --> AE4
        end

        STRUCTURED --> ADAPTER --> EVIDENCE --> ARTICLE
    end

    subgraph PHASE3["PHASE 3: PARSER + RESOLVER"]
        direction TB

        subgraph DPARSER["Deterministic Parser"]
            direction TB
            DP1["DeterministicParser class<br/>extractFromEvidencePack()"]
            DP2["<b>1. Regex Patterns</b><br/>parseRegexPatterns()<br/>template.patterns[].regex<br/>+ contextMatch (pos/neg kw)<br/><b>confidence: 0.95</b>"]
            DP3["<b>2. Spec Table Match</b><br/>parseSpecRows()<br/>split on | delimiter<br/>fuzzy match ≥ 0.78<br/><b>confidence: 0.80-0.98</b>"]
            DP4["<b>3. JSON-LD Path</b><br/>parseJsonLd()<br/>explicit path → fallback paths<br/>(field, additionalProperty)<br/><b>confidence: 0.90</b>"]
            DP1 --> DP2 --> DP3 --> DP4
        end

        subgraph COMPONENT["Component Resolver"]
            direction TB
            CR1["ComponentResolver class<br/>resolveFromCandidates()"]
            CR2["<b>Phase 1: Best candidate</b><br/>per field with component_db_ref<br/>score: table=4, template=3,<br/>json_ld=2, other=1"]
            CR3["<b>Phase 2: Fuzzy match</b><br/>against component DB<br/>threshold: 0.7 (configurable)<br/>infer properties → fields<br/>via PROPERTY_FIELD_MAP"]
            CR4["<b>Confidence by variance:</b><br/>authoritative: 0.85<br/>upper/lower_bound: 0.80<br/>range: 0.75<br/>override_allowed: 0.60"]
            CR5["<b>Phase 3: Constraints</b><br/>evaluateAllConstraints()<br/>direct violation: ×0.5<br/>indirect violation: ×0.85"]
            CR1 --> CR2 --> CR3 --> CR4 --> CR5
        end

        subgraph LLM["LLM Extraction (Conditional)"]
            direction TB
            LL1["extractCandidatesLLM()<br/><b>Only if:</b> llmEnabled +<br/>unfilled fields + budget OK"]
            LL2["<b>Batch processing:</b><br/>max 7 batches/product<br/>6 snippets + 6 images/batch<br/>900 chars/snippet"]
            LL3["<b>Evidence scoping:</b><br/>hintHits: 5× score<br/>lexicalHits: 3×<br/>dimensionSignal: 2×<br/>textType: 1×"]
            LL4["<b>LLM call:</b><br/>multimodal (text + images)<br/>JSON schema output<br/>max tokens: 1200<br/>reasoning budget: 4096"]
            LL5["<b>Sanitization:</b><br/>validate evidence refs<br/>drop unknown fields<br/>drop invalid/missing refs<br/>method: llm_extract"]
            LL1 --> LL2 --> LL3 --> LL4 --> LL5
        end

        subgraph PRIORITY["Method Priority"]
            direction TB
            PR1["<b>Extraction priority:</b>"]
            PR2["network_json / adapter_api /<br/>spec_table_match: <b>5</b>"]
            PR3["parse_template: <b>4.5</b><br/>json_ld / embedded_state: <b>4</b>"]
            PR4["pdf_table / pdf: <b>3</b><br/>dom / component_db: <b>2</b>"]
            PR5["llm_extract: <b>1</b> (lowest)"]
            PR1 --> PR2 --> PR3 --> PR4 --> PR5
        end

        DPARSER --> COMPONENT --> LLM --> PRIORITY
    end

    subgraph PHASE4["PHASE 4: IDENTITY GATE + CONSENSUS"]
        direction TB

        subgraph IDENTITY["Identity Gating"]
            direction TB
            IG1["applyIdentityGateToCandidates()"]
            IG2["<b>10 gated fields:</b><br/>brand, model, variant, sku,<br/>base_model, mpn, gtin,<br/>upc, ean, asin"]
            IG3["<b>resolveIdentityLabel():</b><br/>match=true → 'matched'<br/>criticalConflicts → 'different'<br/>score ≥ 0.4 → 'possible'<br/>default → 'different'"]
            IG4["<b>Source filtering:</b><br/>'different' → rejected<br/>'matched' / 'possible' → pass"]
            IG1 --> IG2 --> IG3 --> IG4
        end

        subgraph CONSENSUS["Consensus Engine"]
            direction TB
            CE1["runConsensusEngine()"]
            CE2["<b>Score per candidate:</b><br/>TIER_WEIGHT × METHOD_WEIGHT<br/>Tier 1: 1.0, Tier 2: 0.8<br/>Tier 3: 0.45"]
            CE3["<b>Cluster by value:</b><br/>track approvedDomainCount<br/>+ instrumentedDomains<br/>selectBestCluster()"]
            CE4["<b>Strict acceptance:</b><br/>≥ 2 approved domains<br/>AND best ≥ 1.1× second<br/><b>Instrumented:</b> + ≥ 3 lab sources"]
            CE5["<b>Confidence:</b><br/>base: 0.7 (if ≥2 approved)<br/>+0.2 if weighted majority<br/>+0.1 if high method score"]
            CE1 --> CE2 --> CE3 --> CE4 --> CE5
        end

        subgraph REDUCERS["Post-Consensus Reducers"]
            direction TB
            RD1["<b>1. Selection policy:</b><br/>numeric fields → median<br/>within tolerance_ms"]
            RD2["<b>2. List union:</b><br/>multi-value dedup"]
            RD3["<b>3. Core/Deep gates:</b><br/>reject low-tier evidence<br/>for core facts"]
            RD4["<b>Battery rule:</b><br/>wired + no battery<br/>→ battery_hours = 'n/a'"]
            RD1 --> RD2 --> RD3 --> RD4
        end

        subgraph OUTPUT["Consensus Output"]
            direction TB
            O1["<b>fields:</b><br/>{ field: consensus_value }"]
            O2["<b>provenance:</b><br/>per-field evidence chain<br/>confirmations, approved_domains,<br/>confidence, citations"]
            O3["<b>fieldsBelowPassTarget:</b><br/>fields needing more evidence<br/>pass target: 2 (normal)<br/>4 (identity/critical)"]
            O4["<b>agreementScore:</b> 0-1<br/>cross-source agreement<br/>→ Repair / Hypothesis phases"]
            O1 --> O2 --> O3 --> O4
        end

        IDENTITY --> CONSENSUS --> REDUCERS --> OUTPUT
    end

    PHASE1 ==>|"fieldCandidates +<br/>identityCandidates"| PHASE2
    PHASE2 ==>|"evidence pack +<br/>adapter candidates"| PHASE3
    PHASE3 ==>|"all candidates +<br/>inferred fields"| PHASE4

    style PHASE1 fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style PHASE2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:3px
    style PHASE3 fill:#fff3e0,stroke:#e65100,stroke-width:3px
    style PHASE4 fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px
    style INPUT fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style BUCKETS fill:#e0f7fa,stroke:#00838f,stroke-width:1px
    style FLATTEN fill:#fff8e1,stroke:#f9a825,stroke-width:1px
    style DOM fill:#efebe9,stroke:#5d4037,stroke-width:1px
    style STRUCTURED fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style ADAPTER fill:#e0f7fa,stroke:#00838f,stroke-width:2px
    style EVIDENCE fill:#ede7f6,stroke:#512da8,stroke-width:2px
    style ARTICLE fill:#fff8e1,stroke:#f9a825,stroke-width:1px
    style DPARSER fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style COMPONENT fill:#e8eaf6,stroke:#283593,stroke-width:2px
    style LLM fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style PRIORITY fill:#efebe9,stroke:#5d4037,stroke-width:1px
    style IDENTITY fill:#ede7f6,stroke:#512da8,stroke-width:2px
    style CONSENSUS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style REDUCERS fill:#e0f2f1,stroke:#00695c,stroke-width:1px
    style OUTPUT fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px
