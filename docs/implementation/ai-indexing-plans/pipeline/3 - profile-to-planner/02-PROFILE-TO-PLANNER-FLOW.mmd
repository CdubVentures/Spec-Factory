flowchart TD
  START["runDiscoverySeedPlan()"] --> GATE{"enableSchema4SearchPlan?"}

  %% ─── Schema 4 Path (NeedSet Planner) ───
  GATE -- "YES (Schema 4)" --> S4_CTX["buildSearchPlanningContext()<br/>Schema 2 → Schema 3<br/>focus_groups + planner_limits + catalog"]

  subgraph S4["Schema 4: NeedSet Planner (searchPlanBuilder.js)"]
    S4_CTX --> S4_GATE{"hasLlmRouteApiKey<br/>role=plan?"}
    S4_GATE -- "NO" --> S4_DISABLED["makeDisabledResult()<br/>mode=disabled, 0 queries<br/>full panel metadata preserved"]
    S4_GATE -- "YES" --> S4_FILTER["Pre-LLM anti-garbage filter<br/>remove dead_domains from domain_hints_union<br/>remove dead_query_hashes from existing_queries_union<br/>filter to phase=now|next groups only"]
    S4_FILTER --> S4_PAYLOAD["Build LLM payload<br/>identity + round + missing_critical_fields<br/>limits + focus_groups (unions capped to 5)<br/>existing_queries"]
    S4_PAYLOAD --> S4_LLM["callLlmWithRouting()<br/>reason=needset_search_planner<br/>role=plan<br/>model=config.llmModelPlan<br/>timeout=40s<br/>jsonSchema=PLANNER_RESPONSE_SCHEMA"]
    S4_LLM -- "error" --> S4_ERROR["makeErrorResult()<br/>mode=error, 0 queries<br/>full panel metadata preserved"]
    S4_LLM -- "success" --> S4_NORM["Normalize LLM response<br/>array groups OR single group → [group]<br/>empty fallback → []"]
    S4_NORM --> S4_DEDUP["Post-LLM dedup + cap<br/>hash vs existing_queries<br/>per-group cap: 3<br/>global cap: max(1, discoveryMaxQueries)"]
    S4_DEDUP --> S4_ASM["assembleSchema4()<br/>search_plan_handoff: queries + hashes + total<br/>panel: bundles + profile_influence + deltas<br/>learning_writeback: families + domains + groups"]
  end

  S4_DISABLED --> S4_OUT["Schema 4 Output<br/>needset_planner_output.v2"]
  S4_ERROR --> S4_OUT
  S4_ASM --> S4_OUT

  S4_OUT --> HANDOFF["runDiscoverySeedPlan attaches<br/>_planner, _learning, _panel<br/>to search_plan_handoff"]
  HANDOFF --> DISCOVER["discoverCandidateSources()<br/>convertHandoffToExecutionPlan()<br/>→ executeSearchQueries()"]

  %% ─── Old Path (multi-pass planner) ───
  GATE -- "NO (old path)" --> OLD_PROFILE["buildSearchProfile()<br/>deterministic aliases + query rows<br/>base_templates + field hints"]

  subgraph OLD["Old Path: Multi-Pass Discovery Planner"]
    OLD_PROFILE --> OLD_EXTRACT["searchDiscovery extracts<br/>baseQueries + targetedQueries<br/>profileQueryRowsByQuery map"]
    OLD_EXTRACT --> OLD_LLM["planDiscoveryQueriesLLM()<br/>Standard: primary pass only<br/>Aggressive: fast+reason+validate"]
    OLD_LLM --> OLD_UBER["Uber planner (uber_aggressive only)<br/>planUberQueries()"]
    OLD_UBER --> OLD_MERGE["Merge: base + targeted + llm + uber + extra<br/>dedupeQueryRows() → prioritizeQueryRows()"]
  end

  OLD_MERGE --> DISCOVER

  %% ─── Styling ───
  classDef s4class fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20
  classDef oldclass fill:#fff3e0,stroke:#ef6c00,color:#e65100
  classDef gateclass fill:#e3f2fd,stroke:#1565c0,color:#0d47a1

  class S4_CTX,S4_FILTER,S4_PAYLOAD,S4_LLM,S4_NORM,S4_DEDUP,S4_ASM s4class
  class OLD_PROFILE,OLD_EXTRACT,OLD_LLM,OLD_UBER,OLD_MERGE oldclass
  class GATE,S4_GATE gateclass
