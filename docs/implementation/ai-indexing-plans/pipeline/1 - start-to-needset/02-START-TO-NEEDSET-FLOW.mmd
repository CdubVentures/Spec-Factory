flowchart TD
  A["runProduct()<br/>fieldOrder = categoryConfig.fieldOrder"] --> B["Initial baseline NeedSet<br/>computeNeedSet()<br/>provenance = {}<br/>fieldReasoning = {}<br/>constraintAnalysis = {}"]
  A --> C["Discovery + consensus + validation already ran<br/>provenance, sourceResults, completenessStats,<br/>identityGate, identityConfidence,<br/>publishable, publishBlockers, identityReport"]
  C --> D["buildConstraintAnalysisContext()<br/>constraintAnalysis"]
  C --> E["buildNeedsetReasoningContext()"]

  subgraph R["Finalized NeedSet assembly"]
    E --> F["Filter helper synthetic sources<br/>for hypothesisQueue + fieldReasoning only"]
    F --> G["buildHypothesisQueue()<br/>criticalFieldsBelowPassTarget<br/>missingRequiredFields<br/>sourceIntel domains<br/>maxHypothesisItems"]
    F --> H["buildFieldReasoning()<br/>unknown_reason + contradictions<br/>blocked/budget story<br/>searchAttemptCount"]
    H --> I["buildTrafficLight()<br/>green = component_db or Tier 1<br/>yellow = Tier 2<br/>red = unknown or weak evidence"]
    C --> J["deriveNeedSetIdentityState()<br/>locked / conflict / provisional / unlocked"]
    C --> K["buildNeedSetIdentityAuditRows()"]
    J --> L["needSetIdentityContext<br/>status, confidence, publishable,<br/>publish_blockers, reason_codes,<br/>contradictions, max_match_score,<br/>audit_rows<br/>extraction_gate_open = true"]
    K --> L
    D --> M["Final computeNeedSet()"]
    H --> M
    L --> M
  end

  A --> M

  subgraph N["computeNeedSet() live scoring"]
    M --> N1["collectFieldKeys()<br/>fieldOrder + provenance + fieldRules"]
    N1 --> N2["Per field read:<br/>required_level<br/>min_evidence_refs<br/>tier_preference<br/>value/confidence/pass_target/evidence"]
    N2 --> N3["Derive deficits:<br/>missing<br/>low_conf<br/>min_refs_fail<br/>tier_pref_unmet<br/>conflict<br/>publish_gate_block"]
    N3 --> N4["Score and sort<br/>need_score DESC<br/>required weight DESC<br/>field_key ASC"]
  end

  G --> O["Side output:<br/>hypothesisQueue"]
  I --> P["Side output:<br/>trafficLight"]
  N4 --> Q["NeedSet output<br/>needs[]<br/>reason_counts<br/>required_level_counts<br/>identity_lock_state<br/>identity_audit_rows<br/>snapshots[]"]
