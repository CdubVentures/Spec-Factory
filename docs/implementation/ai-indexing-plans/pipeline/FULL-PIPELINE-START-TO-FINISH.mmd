        S11 --> S12 --> S13
    end

    BRAND["Brand Sidecar<br/>parallel to NeedSet and planning<br/>feeds domain hints + aliases<br/>supports host promotion"]
    EVENTS["Data Change And Runtime Ops<br/>finalization telemetry packets<br/>broadcast + review surfaces<br/>observability counters"]
