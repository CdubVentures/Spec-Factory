flowchart LR
    subgraph PHASE1["PHASE 1: DISCOVERY RESULT CONTRACT"]
        direction TB

        A1["Input from folder 6:<br/>discoveryResult"]
        A2["Disabled path:<br/>enabled false<br/>empty arrays<br/>null artifact keys"]
        A3["Enabled path:<br/>candidates[]<br/>approvedUrls[]<br/>candidateUrls[]<br/>search_profile<br/>serp_explorer"]

        A1 --> A2
        A1 --> A3
    end

    subgraph PHASE2["PHASE 2: RUN DISCOVERY SEED PLAN"]
        direction TB

        B1["runDiscoverySeedPlan()"]
        B2["approvedUrls -><br/>planner.enqueue(url, discovery_approved,<br/>forceApproved true)"]
        B3["candidateUrls -> gate:<br/>enabled and maxCandidateUrls > 0<br/>and fetchCandidateSources"]
        B4["planner.seedCandidates()<br/>-> enqueue(url, discovery,<br/>forceCandidate true)"]

        B1 --> B2
        B1 --> B3 --> B4
    end

    subgraph PHASE3["PHASE 3: PLANNER REVALIDATION"]
        direction TB

        C1["SourcePlanner.enqueue()"]
        C2["Rechecks:<br/>URL parse + protocol<br/>queue dedupe<br/>denylist + blocked hosts"]
        C3["More gates:<br/>low-value host<br/>validateFetchUrl()<br/>brand manufacturer restriction<br/>locked manufacturer guards"]
        C4["Caps still apply:<br/>maxUrlsPerProduct<br/>maxCandidateUrls<br/>maxPagesPerDomain<br/>manufacturer caps"]

        C1 --> C2 --> C3 --> C4
    end

    subgraph PHASE4["PHASE 4: QUEUE ROUTING"]
        direction TB

        D1["Approved manufacturer -> manufacturerQueue"]
        D2["Approved non-manufacturer -> queue"]
        D3["Candidate rows -> candidateQueue"]
        D4["Not frontloaded here:<br/>priorityQueue only for<br/>seed / learning_seed"]

        D1 --> D4
        D2 --> D4
        D3 --> D4
    end

    subgraph PHASE5["PHASE 5: SNAPSHOT + ARTIFACT SURFACES"]
        direction TB

        E1["runPlannerQueueSnapshotPhase()<br/>writes queue_snapshot trace"]
        E2["buildRunSummaryPayload()<br/>records discoveryKey<br/>candidatesKey<br/>search profile keys"]
        E3["runArtifactReaders()<br/>resolves search_profile<br/>and serp_explorer from outputs<br/>and _discovery fallbacks"]
        E4["queryLearning()<br/>uses discoveryResult.candidates<br/>and queries"]
        E5["Next live step:<br/>fetcher starts from planner queues"]

        E1 --> E2 --> E3 --> E4 --> E5
    end

    PHASE1 --> PHASE2 --> PHASE3 --> PHASE4 --> PHASE5

    style PHASE1 fill:#e0f2fe,stroke:#0369a1,stroke-width:3px
    style PHASE2 fill:#ecfccb,stroke:#4d7c0f,stroke-width:3px
    style PHASE3 fill:#dcfce7,stroke:#166534,stroke-width:3px
    style PHASE4 fill:#fef3c7,stroke:#b45309,stroke-width:3px
    style PHASE5 fill:#fee2e2,stroke:#b91c1c,stroke-width:3px
