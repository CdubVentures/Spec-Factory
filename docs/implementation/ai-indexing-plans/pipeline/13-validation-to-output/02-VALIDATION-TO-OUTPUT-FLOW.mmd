    style PROMOTE fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style FINAL fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style META fill:#e0f7fa,stroke:#00838f,stroke-width:1px
    style LEARNING fill:#e8eaf6,stroke:#283593,stroke-width:2px
    style STORES fill:#fff8e1,stroke:#f9a825,stroke-width:2px
