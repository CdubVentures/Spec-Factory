%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '16px', 'fontFamily': 'Segoe UI', 'primaryColor': '#1565c0', 'primaryTextColor': '#fff', 'primaryBorderColor': '#0d47a1', 'lineColor': '#444', 'secondaryColor': '#e3f2fd', 'tertiaryColor': '#bbdefb'}}}%%

flowchart LR
    subgraph PHASE1["PHASE 1: RUN COMPLETION + ARTIFACT EXPORT"]
        direction TB

        subgraph COMPLETION["Run Completion Sequence"]
            direction TB
            RC1["<b>runFinalizationTelemetryPhase()</b><br/>emit indexing schema events"]
            RC2["<b>buildRunCompletedPayload()</b><br/>aggregate full run state<br/>+ emitRunCompletedEvent()"]
            RC3["<b>buildSummaryArtifacts()</b><br/>TSV row + markdown summary"]
            RC4["<b>runIdentityReportPersistence()</b><br/>+ runSourceIntelFinalization()"]
            RC1 --> RC2 --> RC3 --> RC4
        end

        subgraph EXPORT["exportRunArtifacts()"]
            direction TB
            EX1["<b>Tier 1: runs/{runId}/</b><br/>raw pages (gzipped),<br/>DOM snippets, screenshots,<br/>PDFs, network responses"]
            EX2["<b>Extracted + Normalized:</b><br/>candidates.json per host<br/>normalized.json + row.tsv<br/>provenance + candidates"]
            EX3["<b>Tier 2: latest/</b><br/>normalized, provenance,<br/>compactSummary (23 fields),<br/>candidates, TSV, markdown"]
            EX4["<b>Events:</b><br/>events.jsonl.gz<br/>+ summary.json (full)"]
            EX1 --> EX2 --> EX3 --> EX4
        end

        subgraph SPECDB["SpecDb Dual-Write"]
            direction TB
            SD1["<b>SQLite transaction:</b><br/>4 tables in single tx"]
            SD2["<b>product_runs:</b><br/>upsert run record<br/>is_latest = true"]
            SD3["<b>item_field_state:</b><br/>per-field upsert<br/>needsAiReview if conf < 0.8"]
            SD4["<b>candidates:</b><br/>scoped IDs + dedup<br/><b>product_queue:</b><br/>rounds + 1, status update"]
            SD1 --> SD2 --> SD3 --> SD4
        end

        COMPLETION --> EXPORT --> SPECDB
    end

    subgraph PHASE2["PHASE 2: FINAL OUTPUT + PROMOTION"]
        direction TB

        subgraph RUNTIME["Runtime Field Rules"]
            direction TB
            RT1["<b>applyKeyMigrations()</b><br/>renamed field mapping"]
            RT2["<b>applyRuntimeFieldRules()</b><br/>normalization + validation<br/>+ evidence enforcement"]
            RT3["<b>Output:</b><br/>applied, failures[],<br/>warnings[], changes[]"]
            RT1 --> RT2 --> RT3
        end

        subgraph PROMOTE["shouldPromoteFinal()"]
            direction TB
            PR1["<b>Candidate not publishable</b><br/>→ DO NOT promote"]
            PR2["<b>No existing summary</b><br/>→ PROMOTE (first run)<br/><b>Existing not publishable</b><br/>→ PROMOTE"]
            PR3["<b>Compare cascade:</b><br/>1. completeness (ε=1e-9)<br/>2. confidence (ε=1e-9)<br/>3. contradictions (fewer)<br/>4. generatedAt (newer)"]
            PR1 --> PR2 --> PR3
        end

        subgraph FINAL["Final Output Files"]
            direction TB
            FO1["<b>Promoted (if better):</b><br/>final/{brand}/{model}/"]
            FO2["<b>spec.json</b> — field values<br/><b>summary.json</b> — compact<br/><b>provenance.json</b> — evidence<br/>+ reasoning + traffic light"]
            FO3["<b>traffic_light.json</b><br/><b>meta.json</b> — bestUrls,<br/>canonical identity,<br/>publishable status"]
            FO4["<b>Always appended:</b><br/>history/runs.jsonl<br/>evidence/sources.jsonl<br/><b>evidence_pack.json</b><br/>(max 300 refs, deduped)"]
            FO1 --> FO2 --> FO3 --> FO4
        end

        subgraph META["meta.json Construction"]
            direction TB
            ME1["<b>bestUrls priority:</b><br/>1. identity-matched URLs<br/>2. approved domain URLs<br/>3. evidence reference URLs<br/>4. fetched URLs"]
            ME2["<b>Filters:</b><br/>isLowValueUrl() excludes<br/>robots.txt, sitemaps,<br/>search pages, query URLs"]
            ME3["<b>urlLikelyMatchesBrand()</b><br/>hostname/path must<br/>contain brand slug<br/>dedup + cap 50"]
            ME1 --> ME2 --> ME3
        end

        RUNTIME --> PROMOTE --> FINAL --> META
    end

    subgraph PHASE3["PHASE 3: LEARNING + PUBLISHING"]
        direction TB

        subgraph LEARNING["Learning Gate"]
            direction TB
            LG1["<b>evaluateFieldLearningGates()</b><br/>per-field acceptance"]
            LG2["<b>Skip 'unk' fields</b><br/>Evaluate: confidence,<br/>refsFound ≥ minRefs (2),<br/>tier history, component ref"]
            LG3["<b>emitLearningGateEvents()</b><br/>learning_gate_result<br/>per field in log"]
            LG1 --> LG2 --> LG3
        end

        subgraph STORES["4 Learning Stores"]
            direction TB
            LS1["<b>urlMemory:</b><br/>field → URL → category<br/>(which URLs yield values)"]
            LS2["<b>domainFieldYield:</b><br/>domain × field rates<br/>recordUsed / recordSeen"]
            LS3["<b>fieldAnchors:</b><br/>evidence quotes as<br/>anchor phrases"]
            LS4["<b>componentLexicon:</b><br/>component_reference values<br/>(sensor, switch, encoder)"]
            LS1 --> LS2 --> LS3 --> LS4
        end

        subgraph PUBLISH["Publishing Pipeline"]
            direction TB
            PB1["<b>Gate 1: Data Quality</b><br/>runtime field rules<br/>any failure → blocked"]
            PB2["<b>Gate 2: Category Gate</b><br/>none → identity_complete<br/>→ required_complete<br/>→ evidence_complete<br/>→ all_validations_pass<br/>→ strict"]
            PB3["<b>Gate 3: Per-Field</b><br/>block_publish_when_unk<br/>per field rule override"]
            PB4["<b>Output:</b><br/>current.json (semver)<br/>compact.json, provenance<br/>schema_product.jsonld<br/>changelog.json<br/>versions/ archive"]
            PB1 --> PB2 --> PB3 --> PB4
        end

        subgraph EXPORTS["Bulk Exports"]
            direction TB
            BE1["<b>Category-level:</b><br/>_index.json (all products)<br/>_changelog.json (recent)"]
            BE2["<b>exports/feed.json</b><br/>last 100 published"]
            BE3["<b>all_products.csv</b><br/>full CSV export"]
            BE4["<b>all_products.sqlite</b><br/>SQLite database<br/>(via Python spawn)"]
            BE1 --> BE2 --> BE3 --> BE4
        end

        LEARNING --> STORES --> PUBLISH --> EXPORTS
    end

    subgraph PHASE4["PHASE 4: EVENTS + FINALIZATION"]
        direction TB

        subgraph EVENTS["Data Change Events"]
            direction TB
            DC1["<b>49 event types</b><br/>mapped to domains"]
            DC2["<b>process-completed →</b><br/>studio, review-layout,<br/>component, enum"]
            DC3["<b>createDataChangePayload()</b><br/>type, event, category,<br/>domains, version,<br/>entities, meta, ts"]
            DC4["<b>emitDataChange()</b><br/>WebSocket broadcast<br/>+ observability counter"]
            DC1 --> DC2 --> DC3 --> DC4
        end

        subgraph RELOCATE["Run Data Relocation"]
            direction TB
            RD1["<b>Stage-then-move:</b><br/>copy to temp staging dir"]
            RD2["<b>Bundle contents:</b><br/>run_output, latest_snapshot,<br/>indexlab, runtime_traces,<br/>shared_logs, manifest.json"]
            RD3["<b>Local:</b> ~/Desktop/<br/>SpecFactoryRuns/{cat}/{prod}/{run}<br/><b>S3:</b> s3://{bucket}/<br/>{prefix}/{cat}/{prod}/{run}"]
            RD4["<b>Cleanup:</b><br/>purge JSONL sources,<br/>delete originals,<br/>remove staging (finally)"]
            RD1 --> RD2 --> RD3 --> RD4
        end

        subgraph FINALIZE["finalizeRunLifecycle()"]
            direction TB
            FL1["<b>emitFieldDecisionEvents()</b><br/>per-field structured log"]
            FL2["<b>field_decision:</b><br/>field, value, decision,<br/>unknown_reason, confidence,<br/>evidence_count,<br/>traffic_color"]
            FL3["<b>frontierDb.save()</b><br/>persist frontier database"]
            FL4["<b>logger.flush()</b><br/>flush all NDJSON buffers<br/><b>→ RUN COMPLETE</b>"]
            FL1 --> FL2 --> FL3 --> FL4
        end

        subgraph RETURN["Return Payload"]
            direction TB
            RP1["<b>buildRunResultPayload()</b>"]
            RP2["<b>job</b> — original input<br/><b>normalized</b> — final fields<br/><b>provenance</b> — evidence<br/><b>summary</b> — validation"]
            RP3["<b>exportInfo</b> — run/latest paths<br/><b>finalExport</b> — final/ paths<br/><b>learning</b> — store results"]
            RP4["<b>learningGateResult</b><br/>per-field verdicts<br/><b>categoryBrain</b><br/>updated learning model"]
            RP1 --> RP2 --> RP3 --> RP4
        end

        EVENTS --> RELOCATE --> FINALIZE --> RETURN
    end

    PHASE1 ==>|"artifacts +<br/>SpecDb persisted"| PHASE2
    PHASE2 ==>|"final output +<br/>promotion decision"| PHASE3
    PHASE3 ==>|"learning stored +<br/>published"| PHASE4

